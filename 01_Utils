    jan:0, januari:0,
    feb:1, februari:1,
    mar:2, maret:2,
    apr:3, april:3,
    mei:4,
    jun:5, juni:5,
    jul:6, juli:6,
    agu:7, ags:7, agustus:7, aug:7, august:7,
    sep:8, september:8,
    okt:9, oktober:9, oct:9, october:9,
    nov:10, november:10,
    des:11, desember:11, dec:11, december:11
  };
