  if (!range || isDryRun_()) return;
  const o = opts || {};
  const clearContents = (o.clearContents !== false);
  const clearFormat = (o.clearFormat !== false);
  const clearNotes = !!o.clearNotes;
  const preserveDv = (o.preserveDataValidations !== false);

