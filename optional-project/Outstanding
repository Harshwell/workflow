function test_tatNormalization() {
  if (normalizeTatValue_(47) !== 47) throw new Error('Numeric TAT normalization failed');
  if (normalizeTatValue_('47') !== 47) throw new Error('String TAT normalization failed');

  var d = new Date(1900, 1, 15); // 15/02/1900 -> expected serial 47 in Sheets
  if (normalizeTatValue_(d) !== 47) throw new Error('Date TAT normalization failed');
}
