/** =============================================================================
 *  RETRY + CIRCUIT BREAKER
 *  ===========================================================================*/
var Retry = {
  computeBackoffMs_: function(attempts) {
    var exp = attempts;
    if (exp < 1) exp = 1;
    if (exp > 8) exp = 8;

    var base = CFG.BASE_BACKOFF_MS * Math.pow(2, exp - 1);
    var jitter = Math.floor(Math.random() * 250);
    var v = base + jitter;
    return v > CFG.MAX_BACKOFF_MS ? CFG.MAX_BACKOFF_MS : v;
  }
};

var CircuitBreaker = {
  isOpen_: function() {
    var props = PropertiesService.getScriptProperties();
    var openUntil = Number(props.getProperty('CB_OPEN_UNTIL_MS') || '0');
    return new Date().getTime() < openUntil;
  },

  onFailure_: function() {
    var props = PropertiesService.getScriptProperties();
    var n = Number(props.getProperty('CB_FAIL_COUNT') || '0') + 1;
    props.setProperty('CB_FAIL_COUNT', String(n));
    if (n >= CFG.CB_OPEN_AFTER_CONSEC_FAILURES) {
      props.setProperty('CB_OPEN_UNTIL_MS', String(new Date().getTime() + CFG.CB_OPEN_MS));
    }
  },

  onSuccess_: function() {
    var props = PropertiesService.getScriptProperties();
    props.setProperty('CB_FAIL_COUNT', '0');
    props.setProperty('CB_OPEN_UNTIL_MS', '0');
  },

  onError_: function() {
    this.onFailure_();
  }
};


/** =============================================================================
 *  LOGGER (structured JSON in Logger)
 *  ===========================================================================*/
var LoggerFactory = {
  scoped: function(runId, scope, baseCtx) {
    return new ScopedLogger_(runId, scope, baseCtx || {});
  }
};

function ScopedLogger_(runId, scope, baseCtx) {
  this.runId = runId;
  this.scope = scope;
  this.baseCtx = baseCtx || {};
  this.level = 'INFO';
}

ScopedLogger_.prototype.info = function(msg, ctx) { this._log_('INFO', msg, ctx); };
ScopedLogger_.prototype.warn = function(msg, ctx) { this._log_('WARN', msg, ctx); };
ScopedLogger_.prototype.error = function(msg, ctx) { this._log_('ERROR', msg, ctx); };

ScopedLogger_.prototype._log_ = function(level, msg, ctx) {
  this.level = level;
  var payload = {
    ts: new Date().toISOString(),
    level: level,
    runId: this.runId,
    scope: this.scope,
    msg: msg
  };

  // merge contexts
  var k;
  for (k in this.baseCtx) {
    if (this.baseCtx.hasOwnProperty(k)) payload[k] = this.baseCtx[k];
  }
  if (ctx) {
    for (k in ctx) {
      if (ctx.hasOwnProperty(k)) payload[k] = ctx[k];
    }
  }

  Logger.log(JSON.stringify(payload));
};


