/** =============================================================================
 *  RUN STORE (_Runs)
 *  ===========================================================================*/
var RunStore = {
  createRun_: function(run) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);
    sh.appendRow([
      run.runId, run.hourKey, run.status, run.createdAt,
      run.totalTasks, run.doneTasks, run.failedTasks, run.notes
    ]);
  },

  hasRunForHour_: function(hourKey) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);
    var lastRow = sh.getLastRow();
    if (lastRow <= 1) return false;

    var data = sh.getRange(2, 1, lastRow - 1, 8).getValues();
    for (var i = data.length - 1; i >= 0; i--) {
      var r = data[i];
      if (String(r[1]) === String(hourKey)) return true;
    }
    return false;
  },

  findRowByRunId_: function(runId) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);
    var lastRow = sh.getLastRow();
    if (lastRow <= 1) return 0;

    var data = sh.getRange(2, 1, lastRow - 1, 1).getValues();
    for (var i = data.length - 1; i >= 0; i--) {
      if (String(data[i][0]) === String(runId)) return i + 2;
    }
    return 0;
  },

  getRunRecord_: function(runId) {
    var rowN = this.findRowByRunId_(runId);
    if (!rowN) return null;

    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);
    var r = sh.getRange(rowN, 1, 1, 8).getValues()[0];
    return {
      rowNumber: rowN,
      runId: r[0],
      hourKey: r[1],
      status: String(r[2] || ''),
      createdAt: r[3],
      totalTasks: Number(r[4] || 0),
      doneTasks: Number(r[5] || 0),
      failedTasks: Number(r[6] || 0),
      notes: r[7] || ''
    };
  },

  getLatestActiveRun_: function() {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);
    var lastRow = sh.getLastRow();
    if (lastRow <= 1) return null;

    var data = sh.getRange(2, 1, lastRow - 1, 8).getValues();
    for (var i = data.length - 1; i >= 0; i--) {
      var r = data[i];
      var status = String(r[2] || '');
      if (status === 'ENQUEUED' || status === 'RUNNING') {
        return {
          runId: r[0],
          hourKey: r[1],
          status: status,
          createdAt: r[3],
          rowNumber: i + 2
        };
      }
    }
    return null;
  },

  updateRun_: function(runId, patch) {
    var rowN = this.findRowByRunId_(runId);
    if (!rowN) return;

    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);

    if (patch.status != null) sh.getRange(rowN, 3).setValue(patch.status);
    if (patch.createdAt != null) sh.getRange(rowN, 4).setValue(patch.createdAt);
    if (patch.totalTasks != null) sh.getRange(rowN, 5).setValue(patch.totalTasks);
    if (patch.doneTasks != null) sh.getRange(rowN, 6).setValue(patch.doneTasks);
    if (patch.failedTasks != null) sh.getRange(rowN, 7).setValue(patch.failedTasks);
    if (patch.notes != null) sh.getRange(rowN, 8).setValue(patch.notes);
  },

  bumpProgress_: function(runId, inc) {
    var rowN = this.findRowByRunId_(runId);
    if (!rowN) return;

    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);

    var done = Number(sh.getRange(rowN, 6).getValue() || 0);
    var failed = Number(sh.getRange(rowN, 7).getValue() || 0);
    sh.getRange(rowN, 6).setValue(done + (inc.doneInc || 0));
    sh.getRange(rowN, 7).setValue(failed + (inc.failedInc || 0));

    var status = String(sh.getRange(rowN, 3).getValue() || '');
    if (status === 'ENQUEUED') sh.getRange(rowN, 3).setValue('RUNNING');
  },

  isRunOlderThan_: function(runId, ageMs) {
    var rec = this.getRunRecord_(runId);
    if (!rec || !rec.createdAt) return false;
    return (new Date().getTime() - TimeUtil.toTs_(rec.createdAt)) > Number(ageMs || 0);
  },

  computeTerminalStatus_: function(runId) {
    var counts = QueueStore.countStatuses_(runId);
    if ((counts.DEAD || 0) > 0 || (counts.CANCELED || 0) > 0) return 'PARTIAL';
    return 'COMPLETED';
  },

  reset_: function() {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_RUNS);
    var lastRow = sh.getLastRow();
    if (lastRow > 1) sh.getRange(2, 1, lastRow - 1, sh.getLastColumn()).clearContent();
  }
};


/** =============================================================================
 *  QUEUE BUILDER
 *  ===========================================================================*/
var QueueBuilder = {
  buildTasks_: function(runId, sourceSheets, pageSize, log) {
    var overviewSs = SpreadsheetApp.openById(CFG.OVERVIEW_CLAIM_SS_ID);

    var tasks = [];
    for (var i = 0; i < sourceSheets.length; i++) {
      var name = sourceSheets[i];
      var sh = overviewSs.getSheetByName(name);
      if (!sh) {
        log.warn('Source sheet missing; skip task build', { sourceSheet: name });
        Audit.append_(log, { event: 'SOURCE_SHEET_MISSING', sourceSheet: name });
        continue;
      }

      var lastRow = sh.getLastRow();
      if (lastRow <= 1) continue;

      var start = 2;
      while (start <= lastRow) {
        var remaining = lastRow - start + 1;
        var num = Math.min(pageSize, remaining);

        tasks.push({
          rowNumber: 0,
          taskId: Utilities.getUuid(),
          runId: runId,
          status: 'PENDING',
          sourceSheet: name,
          startRow: start,
          numRows: num,
          createdAt: new Date(),
          updatedAt: new Date(),
          attempts: 0,
          nextAttemptAtMs: 0,
          lastError: ''
        });

        start += num;
      }
    }

    log.info('Tasks built', { count: tasks.length });
    return tasks;
  }
};


/** =============================================================================
 *  QUEUE STORE (_Queue)
 *  ===========================================================================*/
var QueueStore = {
  enqueueTasks_: function(tasks, log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    if (!tasks || tasks.length === 0) return;

    var values = [];
    for (var i = 0; i < tasks.length; i++) {
      var t = tasks[i];
      values.push([
        t.taskId, t.runId, t.status, t.sourceSheet, t.startRow, t.numRows,
        t.createdAt, t.updatedAt, t.attempts, t.nextAttemptAtMs, t.lastError
      ]);
    }

    var startRow = sh.getLastRow() + 1;
    sh.getRange(startRow, 1, values.length, values[0].length).setValues(values);

    log.info('Tasks enqueued', { count: tasks.length });
  },

  dequeueAndMarkInProgress_: function(runId, limit, log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    var lastRow = sh.getLastRow();
    if (lastRow <= 1) return [];

    var data = sh.getRange(2, 1, lastRow - 1, 11).getValues();
    var now = new Date().getTime();

    var out = [];
    for (var i = 0; i < data.length && out.length < limit; i++) {
      var r = data[i];
      if (String(r[1]) !== String(runId)) continue;

      var status = String(r[2] || '');
      var nextAttemptAtMs = Number(r[9] || 0);
      var runnable = (status === 'PENDING') || (status === 'RETRY' && nextAttemptAtMs <= now);
      if (!runnable) continue;

      var rowN = i + 2;
      sh.getRange(rowN, 3).setValue('IN_PROGRESS');
      sh.getRange(rowN, 8).setValue(new Date());

      out.push({
        rowNumber: rowN,
        taskId: r[0],
        runId: r[1],
        status: 'IN_PROGRESS',
        sourceSheet: r[3],
        startRow: Number(r[4]),
        numRows: Number(r[5]),
        attempts: Number(r[8] || 0),
        nextAttemptAtMs: nextAttemptAtMs,
        lastError: r[10] || ''
      });
    }

    log.info('Dequeued tasks', { runId: runId, count: out.length });
    return out;
  },

  markDone_: function(task, log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    sh.getRange(task.rowNumber, 3).setValue('DONE');
    sh.getRange(task.rowNumber, 8).setValue(new Date());
    sh.getRange(task.rowNumber, 11).setValue('');
  },

  markFailedOrRetry_: function(task, err, log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);

    var message = err && err.stack ? String(err.stack) : String(err);
    var attempts = Number(task.attempts || 0) + 1;

    if (attempts >= CFG.MAX_RETRY_ATTEMPTS) {
      sh.getRange(task.rowNumber, 3).setValue('DEAD');
      sh.getRange(task.rowNumber, 8).setValue(new Date());
      sh.getRange(task.rowNumber, 9).setValue(attempts);
      sh.getRange(task.rowNumber, 11).setValue(message.slice(0, 5000));

      CircuitBreaker.onFailure_();
      Audit.append_(log, { event: 'TASK_DEAD', taskId: task.taskId, attempts: attempts });
      log.error('Task moved to DEAD', { taskId: task.taskId, attempts: attempts, err: message });
      return;
    }

    var backoff = Retry.computeBackoffMs_(attempts);
    var nextAttemptAtMs = new Date().getTime() + backoff;

    sh.getRange(task.rowNumber, 3).setValue('RETRY');
    sh.getRange(task.rowNumber, 8).setValue(new Date());
    sh.getRange(task.rowNumber, 9).setValue(attempts);
    sh.getRange(task.rowNumber, 10).setValue(nextAttemptAtMs);
    sh.getRange(task.rowNumber, 11).setValue(message.slice(0, 5000));

    CircuitBreaker.onFailure_();
    Audit.append_(log, { event: 'TASK_RETRY', taskId: task.taskId, attempts: attempts, nextAttemptAtMs: nextAttemptAtMs });
    log.warn('Task scheduled for retry', { taskId: task.taskId, attempts: attempts, backoffMs: backoff });
  },

  recoverStaleInProgress_: function(runId, log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    var lastRow = sh.getLastRow();
    if (lastRow <= 1) return 0;

    var data = sh.getRange(2, 1, lastRow - 1, 11).getValues();
    var now = new Date().getTime();
    var fixed = 0;

    for (var i = 0; i < data.length; i++) {
      var r = data[i];
      if (String(r[1]) !== String(runId)) continue;

      var status = String(r[2] || '');
      var updatedAtMs = TimeUtil.toTs_(r[7]);
      if (status !== 'IN_PROGRESS') continue;
      if (!updatedAtMs) updatedAtMs = TimeUtil.toTs_(r[6]);
      if (!updatedAtMs) continue;
      if ((now - updatedAtMs) <= CFG.TASK_STALE_MS) continue;

      var rowN = i + 2;
      var attempts = Number(r[8] || 0) + 1;

      if (attempts >= CFG.MAX_RETRY_ATTEMPTS) {
        sh.getRange(rowN, 3).setValue('DEAD');
        sh.getRange(rowN, 8).setValue(new Date());
        sh.getRange(rowN, 9).setValue(attempts);
        sh.getRange(rowN, 11).setValue('Recovered stale IN_PROGRESS -> DEAD');
      } else {
        var nextAttemptAtMs = new Date().getTime() + Retry.computeBackoffMs_(attempts);
        sh.getRange(rowN, 3).setValue('RETRY');
        sh.getRange(rowN, 8).setValue(new Date());
        sh.getRange(rowN, 9).setValue(attempts);
        sh.getRange(rowN, 10).setValue(nextAttemptAtMs);
        sh.getRange(rowN, 11).setValue('Recovered stale IN_PROGRESS -> RETRY');
      }
      fixed++;
    }

    if (fixed > 0) {
      log.warn('Recovered stale IN_PROGRESS tasks', { runId: runId, count: fixed });
      Audit.append_(log, { event: 'RECOVER_STALE_IN_PROGRESS', runId: runId, count: fixed });
    }
    return fixed;
  },

  countStatuses_: function(runId) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    var lastRow = sh.getLastRow();
    var out = {};
    if (lastRow <= 1) return out;

    var data = sh.getRange(2, 1, lastRow - 1, 3).getValues();
    for (var i = 0; i < data.length; i++) {
      if (String(data[i][1]) !== String(runId)) continue;
      var status = String(data[i][2] || '');
      if (!out[status]) out[status] = 0;
      out[status]++;
    }
    return out;
  },

  cancelOpenTasks_: function(runId, reason, log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    var lastRow = sh.getLastRow();
    if (lastRow <= 1) return 0;

    var data = sh.getRange(2, 1, lastRow - 1, 11).getValues();
    var changed = 0;

    for (var i = 0; i < data.length; i++) {
      var r = data[i];
      if (String(r[1]) !== String(runId)) continue;

      var status = String(r[2] || '');
      if (status !== 'PENDING' && status !== 'RETRY' && status !== 'IN_PROGRESS') continue;

      var rowN = i + 2;
      sh.getRange(rowN, 3).setValue('CANCELED');
      sh.getRange(rowN, 8).setValue(new Date());
      sh.getRange(rowN, 11).setValue(String(reason || 'Canceled'));
      changed++;
    }

    if (changed > 0) {
      log.warn('Canceled open tasks for run', { runId: runId, count: changed, reason: reason || '' });
      Audit.append_(log, { event: 'CANCEL_OPEN_TASKS', runId: runId, count: changed, reason: reason || '' });
    }
    return changed;
  },

  isRunDrained_: function(runId) {
    var counts = this.countStatuses_(runId);
    if ((counts.PENDING || 0) > 0) return false;
    if ((counts.IN_PROGRESS || 0) > 0) return false;
    if ((counts.RETRY || 0) > 0) return false;
    return true;
  },

  reset_: function() {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(CFG.SYS_SHEET_QUEUE);
    var lastRow = sh.getLastRow();
    if (lastRow > 1) sh.getRange(2, 1, lastRow - 1, sh.getLastColumn()).clearContent();
  }
};


/** =============================================================================
 *  SYSTEM MAINTENANCE
 *  ===========================================================================*/
var SystemMaintenance = {
  beforeNewRun_: function(opts, log) {
    opts = opts || {};

    if (opts.forceFresh || CFG.SYSTEM_SHEETS_MODE === 'RESET_EACH_RUN') {
      this.resetSystemState_(log, { clearCircuitBreaker: true, preserveAuditHeaderOnly: true });
      return;
    }

    this.pruneSystemSheets_(log);
    this.resolveActiveRun_(log);
  },

  resolveActiveRun_: function(log) {
    var active = RunStore.getLatestActiveRun_();
    if (!active) return;

    QueueStore.recoverStaleInProgress_(active.runId, log);

    if (QueueStore.isRunDrained_(active.runId)) {
      var status = RunStore.computeTerminalStatus_(active.runId);
      RunStore.updateRun_(active.runId, {
        status: status,
        notes: 'Auto-closed drained run before enqueue'
      });
      Audit.append_(log, { event: 'AUTO_CLOSE_DRAINED_RUN', runId: active.runId, status: status });
      return;
    }

    if (RunStore.isRunOlderThan_(active.runId, CFG.RUN_STALE_MS)) {
      QueueStore.cancelOpenTasks_(active.runId, 'Auto-canceled stale active run', log);
      RunStore.updateRun_(active.runId, {
        status: 'FAILED',
        notes: 'Auto-canceled stale active run'
      });
      Audit.append_(log, { event: 'AUTO_CANCEL_STALE_RUN', runId: active.runId });
    }
  },

  pruneSystemSheets_: function(log) {
    this.pruneSheet_(CFG.SYS_SHEET_RUNS, CFG.KEEP_RUN_ROWS);
    this.pruneSheet_(CFG.SYS_SHEET_QUEUE, CFG.KEEP_QUEUE_ROWS);
    this.pruneSheet_(CFG.SYS_SHEET_AUDIT, CFG.KEEP_AUDIT_ROWS);
    this.pruneSheet_(CFG.SYS_SHEET_STAGING, CFG.KEEP_STAGING_ROWS);
    log.info('System sheets pruned', {
      keepRuns: CFG.KEEP_RUN_ROWS,
      keepQueue: CFG.KEEP_QUEUE_ROWS,
      keepAudit: CFG.KEEP_AUDIT_ROWS,
      keepStaging: CFG.KEEP_STAGING_ROWS
    });
  },

  pruneSheet_: function(sheetName, keepRows) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var sh = ss.getSheetByName(sheetName);
    if (!sh) return;

    var bodyRows = sh.getLastRow() - 1;
    var keep = Number(keepRows || 0);
    if (bodyRows <= keep) return;

    var deleteCount = bodyRows - keep;
    sh.deleteRows(2, deleteCount);
  },

  resetSystemState_: function(log, opts) {
    opts = opts || {};
    RunStore.reset_();
    QueueStore.reset_();
    Staging.resetAll_();
    Audit.reset_();

    if (opts.clearCircuitBreaker) this.clearScriptFlags_();

    Audit.append_(log, { event: 'SYSTEM_STATE_RESET' });
  },

  clearScriptFlags_: function() {
    var props = PropertiesService.getScriptProperties();
    props.deleteProperty('CB_FAIL_COUNT');
    props.deleteProperty('CB_OPEN_UNTIL_MS');
  }
};


