/** =============================================================================
 *  PIPELINE: TASK PROCESSOR
 *  ===========================================================================*/
var TaskProcessor = {
  processTask_: function(runId, task, log) {
    var overviewSs = SpreadsheetApp.openById(CFG.OVERVIEW_CLAIM_SS_ID);
    var srcSheet = overviewSs.getSheetByName(task.sourceSheet);
    if (!srcSheet) throw new Error('Source sheet not found: ' + task.sourceSheet);

    var lastCol = srcSheet.getLastColumn();
    if (lastCol === 0) return;

    // Header row (row 1)
    var headerRow = srcSheet.getRange(1, 1, 1, lastCol).getValues()[0];
    var plan = HeaderPlan.fromHeader_(headerRow, CFG.EXPECTED_COLUMNS, log);

    // Data range for this task
    var startRow = task.startRow;
    var numRows = task.numRows;

    var maxRow = srcSheet.getLastRow();
    if (startRow > maxRow) {
      log.info('Task startRow beyond lastRow; skip', { startRow: startRow, maxRow: maxRow });
      return;
    }
    var actualRows = Math.min(numRows, maxRow - startRow + 1);
    if (actualRows <= 0) return;

    var values = srcSheet.getRange(startRow, 1, actualRows, lastCol).getValues();

    // Load mapping once per task (cached in properties)
    var regionMap = StoreRegionRepo.loadPartnerToRegionMap_(log);

    var stagingRows = [];
    for (var i = 0; i < values.length; i++) {
      var row = values[i];

      var claimNumber = plan.getFirst_(row, 'Claim Number');
      if (!String(claimNumber || '').trim()) continue;

      var partnerName = String(plan.getFirst_(row, 'Partner Name') || '').trim();
      var rawStatus = String(plan.getFirst_(row, 'Last Status') || '').trim();
      var serviceCenter = String(plan.getFirst_(row, 'Service Center') || '').trim();

      var destSheet = Router.route_(partnerName, regionMap);
      var pic = PicResolver.resolve_(rawStatus, serviceCenter);
      var translatedStatus = StatusTranslator.translate_(rawStatus);

      if (StatusTranslator.shouldExclude_(rawStatus, translatedStatus)) continue;

      // Build destination row in expected order (+ PIC)
      var destRow = plan.buildDestRow_(row, translatedStatus, pic);

      stagingRows.push([
        runId,
        destSheet,
        String(claimNumber).trim(),
        rawStatus
      ].concat(destRow));
    }

    if (stagingRows.length > 0) {
      Staging.appendRows_(stagingRows, log);
      log.info('Appended to staging', { rows: stagingRows.length });
    } else {
      log.info('No rows appended (empty / filtered)', null);
    }
  }
};



/** =============================================================================
 *  MANUAL PRESERVER (destination columns preserved across refresh)
 *  ===========================================================================*/
var ManualPreserver = {
  // Builds a plan from destination header array: claimColIndex (0-based), preserveCols (array of {colIndex1, name, occurrence})
  buildPlan_: function(header) {
    var claimIdx = findHeaderIndexByOccurrence_(header, 'Claim Number', 1);
    if (claimIdx < 0) return null;

    var preserve = [];
    var cfgList = CFG.PRESERVE_COLUMNS || [];
    for (var i = 0; i < cfgList.length; i++) {
      var item = cfgList[i] || {};
      var nm = String(item.name || '').trim();
      if (!nm) continue;
      var occ = Number(item.occurrence || 1);
      var idx = findHeaderIndexByOccurrence_(header, nm, occ);
      if (idx >= 0) preserve.push({ colIndex1: idx + 1, name: nm, occurrence: occ });
    }

    if (preserve.length === 0) return null;
    return { claimColIndex1: claimIdx + 1, preserveCols: preserve };
  },

  captureByClaim_: function(sheet, plan) {
    if (!plan) return {};
    var lastRow = sheet.getLastRow();
    if (lastRow <= 1) return {};

    var dataRows = lastRow - 1;

    // Claim keys
    var claimVals = sheet.getRange(2, plan.claimColIndex1, dataRows, 1).getValues();
    var claimKeys = [];
    for (var i = 0; i < claimVals.length; i++) {
      claimKeys.push(String(claimVals[i][0] || '').trim());
    }

    var map = {}; // claimKey -> { colIndex1 -> RichTextValue }
    for (var r = 0; r < claimKeys.length; r++) {
      var ck = claimKeys[r];
      if (!ck) continue;
      map[ck] = {};
    }

    // Capture each preserved column as rich text (keeps inline styles)
    for (var p = 0; p < plan.preserveCols.length; p++) {
      var colIndex1 = plan.preserveCols[p].colIndex1;
      var rt = sheet.getRange(2, colIndex1, dataRows, 1).getRichTextValues();

      for (var j = 0; j < claimKeys.length; j++) {
        var key = claimKeys[j];
        if (!key) continue;
        map[key][colIndex1] = rt[j][0]; // RichTextValue
      }
    }

    return map;
  },

  restoreToWrittenRows_: function(sheet, header, outRows, preservedMap, log) {
    if (!preservedMap || !outRows || outRows.length === 0) return;

    var plan = this.buildPlan_(header);
    if (!plan) return;

    var dataRows = outRows.length;
    var claimIdx0 = plan.claimColIndex1 - 1;

    for (var p = 0; p < plan.preserveCols.length; p++) {
      var colIndex1 = plan.preserveCols[p].colIndex1;
      var range = sheet.getRange(2, colIndex1, dataRows, 1);

      var curRt = range.getRichTextValues(); // preserves current values for non-overridden rows
      var overrides = 0;

      for (var i = 0; i < dataRows; i++) {
        var ck = String(outRows[i][claimIdx0] || '').trim();
        if (!ck) continue;

        var perClaim = preservedMap[ck];
        if (perClaim && perClaim[colIndex1]) {
          curRt[i][0] = perClaim[colIndex1];
          overrides++;
        }
      }

      if (overrides > 0) {
        range.setRichTextValues(curRt);
        log.info('Restored preserved column', { col: header[colIndex1 - 1], occurrence: plan.preserveCols[p].occurrence, restoredCells: overrides, sheet: sheet.getName() });
      }
    }
  },
  mergePreservedMaps_: function(target, src, plan) {
  if (!target || !src || !plan) return;
  for (var ck in src) {
    if (!src.hasOwnProperty(ck)) continue;
    if (!ck) continue;

    if (!target[ck]) target[ck] = {};
    var srcObj = src[ck];

    for (var p = 0; p < plan.preserveCols.length; p++) {
      var colIndex1 = plan.preserveCols[p].colIndex1;
      var incoming = srcObj ? srcObj[colIndex1] : null;
      if (!incoming) continue;

      var existing = target[ck][colIndex1];
      var existingBlank = ManualPreserver._isRichTextBlank_(existing);
      var incomingBlank = ManualPreserver._isRichTextBlank_(incoming);

      // Prefer non-blank value; otherwise keep existing.
      if ((existingBlank && !incomingBlank) || !existing) {
        target[ck][colIndex1] = incoming;
      }
    }
  }
},

_isRichTextBlank_: function(rt) {
  try {
    if (!rt) return true;
    var t = rt.getText ? String(rt.getText() || '') : '';
    return t.trim() === '';
  } catch (e) {
    return true;
  }
},

};


/** =============================================================================
 *  FINALIZER: staging -> destination
 *  ===========================================================================*/

var Finalizer = {
  finalizeRun_: function(runId, log) {
    var destSs = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    var staging = destSs.getSheetByName(CFG.SYS_SHEET_STAGING);
    if (!staging) throw new Error('Missing ' + CFG.SYS_SHEET_STAGING);

    var data = staging.getDataRange().getValues();
    if (data.length <= 1) {
      log.warn('Staging empty; nothing to finalize', { runId: runId });
      Audit.append_(log, { event: 'FINALIZE_EMPTY_STAGING', runId: runId });
      return;
    }

    var rows = [];
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][0]) === String(runId)) rows.push(data[i]);
    }
    if (rows.length === 0) {
      log.warn('No staging rows for runId; nothing to finalize', { runId: runId });
      Audit.append_(log, { event: 'FINALIZE_NO_RUN_ROWS', runId: runId });
      return;
    }

    // Column layout:
    // 0 runId, 1 destSheet, 2 claimKey, 3 rawLastStatus, 4.. payload (EXPECTED + PIC)
    var payloadStart = 4;
    var payloadCols = CFG.EXPECTED_COLUMNS.length + 1; // + PIC

    // group: sheetName -> claimKey -> { payload, lsdTs, hasUpdateStatus }
    var grouped = {};
    var deduped = 0;

    var lastStatusDateIdx = indexOf_(CFG.EXPECTED_COLUMNS, 'Last Status Date');
    var updateStatusIdx = indexOf_(CFG.EXPECTED_COLUMNS, 'Update Status');

    for (var r = 0; r < rows.length; r++) {
      var row = rows[r];

      var sheetName = String(row[1] || '').trim();
      if (!sheetName && CFG.CREATE_UNMAPPED_SHEET) sheetName = CFG.DEST_SHEET_UNMAPPED;
      if (!sheetName) continue;

      var claimKey = String(row[2] || '').trim();
      if (!claimKey) continue;

      var payload = row.slice(payloadStart, payloadStart + payloadCols);
      var lsdValue = (lastStatusDateIdx >= 0) ? payload[lastStatusDateIdx] : '';
      var lsdTs = TimeUtil.toTs_(lsdValue);
      var updateStatusVal = (updateStatusIdx >= 0) ? payload[updateStatusIdx] : '';
      var hasUpdateStatus = !isBlank_(updateStatusVal);

      if (!grouped[sheetName]) grouped[sheetName] = {};
      if (!grouped[sheetName][claimKey]) {
        grouped[sheetName][claimKey] = { payload: payload, lsdTs: lsdTs, hasUpdateStatus: hasUpdateStatus };
      } else {
        var prev = grouped[sheetName][claimKey];
        if (hasUpdateStatus && !prev.hasUpdateStatus) {
          grouped[sheetName][claimKey] = { payload: payload, lsdTs: lsdTs, hasUpdateStatus: hasUpdateStatus };
          deduped++;
        } else if (!hasUpdateStatus && prev.hasUpdateStatus) {
          // keep previous row with manual status
        } else if (lsdTs > prev.lsdTs) {
          grouped[sheetName][claimKey] = { payload: payload, lsdTs: lsdTs, hasUpdateStatus: hasUpdateStatus };
          deduped++;
        }
      }
    }

    DestSheets.ensureSpecialSheets(log);

    var header = CFG.EXPECTED_COLUMNS.slice(0);
    header.push(CFG.PIC_COLUMN);

    // Capture preserved manual columns across all managed destination sheets
    var preservePlan = ManualPreserver.buildPlan_(header);
    var globalPreserved = {};
    var managedSheets = [];
    var allSheets = destSs.getSheets();

    for (var si = 0; si < allSheets.length; si++) {
      var sh0 = allSheets[si];
      var nm0 = sh0.getName();
      if (isSystemSheetName_(nm0)) continue;

      var head0 = sh0.getRange(1, 1, 1, header.length).getValues()[0];
      if (!headersMatch_(head0, header)) continue;

      managedSheets.push(sh0);

      if (preservePlan) {
        var local = ManualPreserver.captureByClaim_(sh0, preservePlan);
        ManualPreserver.mergePreservedMaps_(globalPreserved, local, preservePlan);
      }
    }

    if (preservePlan) {
      log.info('Captured preserved manual columns (global)', {
        claims: Object.keys(globalPreserved).length,
        managedSheets: managedSheets.length
      });
    }

    // Clear all existing managed sheets first to avoid stale rows surviving when a region becomes empty.
    for (var ci = 0; ci < managedSheets.length; ci++) {
      DestSheets.clearData_(managedSheets[ci], payloadCols);
    }

    var sheetsWritten = 0;
    var totalWritten = 0;

    for (var name in grouped) {
      if (!grouped.hasOwnProperty(name)) continue;

      var sheet = DestSheets.ensureSheetWithHeader_(destSs, name, log);
      var claimMap = grouped[name];

      var outRows = [];
      for (var ck in claimMap) {
        if (!claimMap.hasOwnProperty(ck)) continue;
        outRows.push(claimMap[ck].payload);
      }

      DestSheets.ensureTemplateRowCoverage_(sheet, outRows.length, payloadCols, log);

      if (outRows.length > 0) {
        sheet.getRange(2, 1, outRows.length, outRows[0].length).setValues(outRows);
        DestSheets.applyPostWriteFormats_(sheet, header, outRows.length, log);
        ManualPreserver.restoreToWrittenRows_(sheet, header, outRows, globalPreserved, log);
      }

      sheetsWritten++;
      totalWritten += outRows.length;
      Audit.append_(log, { event: 'SHEET_WRITTEN', runId: runId, sheet: name, rows: outRows.length });
    }

    log.info('Finalize done', { runId: runId, sheets: sheetsWritten, rows: totalWritten, deduped: deduped });
    Audit.append_(log, { event: 'FINALIZE_DONE', runId: runId, sheets: sheetsWritten, rows: totalWritten, deduped: deduped });
    CircuitBreaker.onSuccess_();
  }
};


/** =============================================================================
 *  ROUTER
 *  ===========================================================================*/
var Router = {
  route_: function(partnerName, regionMap) {
    var pn = String(partnerName || '').trim();
    if (!pn) return CFG.CREATE_UNMAPPED_SHEET ? CFG.DEST_SHEET_UNMAPPED : '';

    var partnerKey = Norm.partnerKey_(pn);

    // Digi override
    if (COMPILED_CFG.DIGI_PARTNER_LOOKUP[partnerKey]) return CFG.DEST_SHEET_DIGI;

    var region = regionMap[partnerKey];
    if (region) return region;

    return CFG.CREATE_UNMAPPED_SHEET ? CFG.DEST_SHEET_UNMAPPED : '';
  }
};


/** =============================================================================
 *  PIC RESOLVER
 *  ===========================================================================*/
var PicResolver = {
  resolve_: function(rawStatus, serviceCenter) {
    var st = String(rawStatus || '').trim();
    if (!st) return 'Unknown';

    if (PIC_GROUPS.ADI_ADIT[st]) return 'Adi & Adit';
    if (PIC_GROUPS.SUCI_YUDHA[st]) return 'Suci & Yudha';

    if (PIC_GROUPS.MIDDLE[st]) {
      return this.resolveMiddle_(serviceCenter);
    }

    return 'Unknown';
  },

  resolveMiddle_: function(serviceCenter) {
    var sc = String(serviceCenter || '').toLowerCase();
    if (!sc) return 'Unknown';

    if (containsAny_(sc, COMPILED_CFG.MIDDLE_SC_KEYWORDS_LOWER.Farhan)) return 'Farhan';
    if (containsAny_(sc, COMPILED_CFG.MIDDLE_SC_KEYWORDS_LOWER.Meilani)) return 'Meilani';
    if (containsAny_(sc, COMPILED_CFG.MIDDLE_SC_KEYWORDS_LOWER.Ivan)) return 'Ivan';

    return 'Unknown';
  }
};


/** =============================================================================
 *  STATUS TRANSLATOR
 *  ===========================================================================*/
var StatusTranslator = {
  translate_: function(rawStatus) {
    var st = String(rawStatus || '').trim();
    if (!st) return '';
    return STATUS_TRANSLATION[st] ? STATUS_TRANSLATION[st] : st;
  },

  shouldExclude_: function(rawStatus, translatedStatus) {
