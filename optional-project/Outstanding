var RunIds = {
  newId: function() {
    return 'run_' +
      Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyyMMdd_HHmmss') +
      '_' +
      Math.floor(Math.random() * 1000000);
  }
};

var TimeUtil = {
  hourKey_: function(d) {
    return Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyyMMdd_HH');
  },

  toTs_: function(v) {
    if (!v) return 0;
    if (v instanceof Date) return v.getTime();
    if (typeof v === 'number') {
      // Apps Script usually returns Date objects; keep conservative
      if (v > 1000000000000) return v;
      return 0;
    }
    var s = String(v).trim();
    var t = Date.parse(s);
    return isNaN(t) ? 0 : t;
  }
};

var Norm = {
  textKey_: function(s) {
    return String(s || '')
      .replace(/\s+/g, ' ')
      .trim()
      .toLowerCase();
  },

  partnerKey_: function(s) {
    return String(s || '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '');
  }
};

function normalizeTatValue_(v) {
  if (v === null || typeof v === 'undefined') return '';
  if (typeof v === 'number') return v;

  if (v instanceof Date) {
    var epoch = new Date(1899, 11, 30);
    var ms = v.getTime() - epoch.getTime();
    return Math.round(ms / 86400000);
  }

  var s = String(v || '').trim();
  if (!s) return '';
  s = s.replace(/,/g, '');

  if (/^-?\d+(\.\d+)?$/.test(s)) return Number(s);

  return s;
}


/** =============================================================================
 *  LOCK WRAPPER
 *  ===========================================================================*/
function withLock_(timeoutMs, fn) {
  var lock = LockService.getScriptLock();
  if (!lock.tryLock(timeoutMs)) throw new Error('Could not acquire script lock (concurrent execution)');
  try {
    return fn();
  } finally {
    lock.releaseLock();
  }
}


/** =============================================================================
 *  SMALL HELPERS (ES5 safe)
 *  ===========================================================================*/
function toLookup_(arr) {
  var o = {};
  for (var i = 0; i < arr.length; i++) o[arr[i]] = true;
  return o;
}

function indexOf_(arr, s) {
  for (var i = 0; i < arr.length; i++) if (String(arr[i]) === String(s)) return i;
  return -1;
}


function isSystemSheetName_(sheetName) {
  var n = String(sheetName || '').trim();
  if (!n) return false;
  if (n === CFG.SYS_SHEET_RUNS) return true;
  if (n === CFG.SYS_SHEET_QUEUE) return true;
  if (n === CFG.SYS_SHEET_STAGING) return true;
  if (n === CFG.SYS_SHEET_AUDIT) return true;
  return false;
}


function findHeaderIndexByOccurrence_(headerArr, name, occurrence) {
  var target = String(name || '').trim().toLowerCase();
  var occ = Number(occurrence || 1);
  var found = 0;
  for (var i = 0; i < headerArr.length; i++) {
    if (String(headerArr[i] || '').trim().toLowerCase() === target) {
      found++;
      if (found === occ) return i;
    }
  }
  return -1;
}


function containsAny_(haystackLower, needlesLowerArr) {
  for (var i = 0; i < needlesLowerArr.length; i++) {
    if (haystackLower.indexOf(String(needlesLowerArr[i]).toLowerCase()) >= 0) return true;
  }
  return false;
}

function mapToTrimStrings_(row) {
  var out = [];
  for (var i = 0; i < row.length; i++) out.push(String(row[i] || '').trim());
  return out;
}

/**
 * Returns true if two header rows match in a case/whitespace-insensitive way.
 * - Compares the first expected.length cells of actual.
 * - Treats null/undefined as ''.
 */
function headersMatch_(actualHeaderRow, expectedHeaderRow) {
  if (!actualHeaderRow || !expectedHeaderRow) return false;
  var a = actualHeaderRow;
  var b = expectedHeaderRow;
  if (a.length < b.length) return false;

  for (var i = 0; i < b.length; i++) {
    var av = String(a[i] || '').trim().replace(/\s+/g, ' ');
    var bv = String(b[i] || '').trim().replace(/\s+/g, ' ');
    if (av.toLowerCase() !== bv.toLowerCase()) return false;
  }
  return true;
}

function isBlank_(v) {
  // Treat null/undefined/empty-string/whitespace as blank. Other falsy values like 0 are NOT blank.
  if (v === null || typeof v === 'undefined') return true;
  if (typeof v === 'string') return v.trim() === '';
  return String(v).trim() === '';
}


