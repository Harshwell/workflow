var DestSheets = {
  ensureSpecialSheets: function(log) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    this.ensureSheetWithHeader_(ss, CFG.DEST_SHEET_DIGI, log);
    if (CFG.CREATE_UNMAPPED_SHEET) this.ensureSheetWithHeader_(ss, CFG.DEST_SHEET_UNMAPPED, log);
  },

  ensureRegionSheets: function(log, regionList) {
    var ss = SpreadsheetApp.openById(CFG.CLAIM_OUTSTANDING_SS_ID);
    for (var i = 0; i < regionList.length; i++) {
      var name = regionList[i];
      if (!name) continue;
      this.ensureSheetWithHeader_(ss, name, log);
    }
  },

  ensureSheetWithHeader_: function(ss, sheetName, log) {
    var sh = ss.getSheetByName(sheetName);
    var created = false;
    if (!sh) {
      sh = ss.insertSheet(sheetName);
      created = true;
      log.info('Created destination sheet', { sheetName: sheetName });
    }

    var header = CFG.EXPECTED_COLUMNS.slice(0);
    header.push(CFG.PIC_COLUMN);

    this.ensureColumns_(sh, header.length);

    // enforce schema header
    sh.getRange(1, 1, 1, header.length).setValues([header]);
    sh.setFrozenRows(1);

    // If this sheet was just created, best-effort copy formatting + data validation from the template sheet's template row.
    if (created) {
      DestSheets._bootstrapTemplateRowFromSheet_(ss, sh, log);
    }

    return sh;
  },

_bootstrapTemplateRowFromSheet_: function(ss, targetSheet, log) {
  try {
    if (!CFG.FORMAT_TEMPLATE_SHEET) return;
    var tpl = ss.getSheetByName(CFG.FORMAT_TEMPLATE_SHEET);
    if (!tpl) return;

    var colCount = CFG.EXPECTED_COLUMNS.length + 1; // + PIC
    this.ensureColumns_(tpl, colCount);
    this.ensureColumns_(targetSheet, colCount);

    var tr = Number(CFG.TEMPLATE_ROW_INDEX || 2);
    if (tr < 2) tr = 2;

    var srcRow = tpl.getRange(tr, 1, 1, colCount);
    var dstRow = targetSheet.getRange(tr, 1, 1, colCount);

    srcRow.copyTo(dstRow, SpreadsheetApp.CopyPasteType.PASTE_FORMAT, false);
    srcRow.copyTo(dstRow, SpreadsheetApp.CopyPasteType.PASTE_DATA_VALIDATION, false);
    log.info('Bootstrapped template row formatting from template sheet', { templateSheet: CFG.FORMAT_TEMPLATE_SHEET, target: targetSheet.getName() });
  } catch (e) {
    // non-fatal
    log.warn('Bootstrap template row failed (non-fatal)', { err: String(e), target: targetSheet.getName() });
  }
},

ensureTemplateRowCoverage_: function(sheet, neededDataRows, colCount, log) {
  // Non-destructive: only formats rows that are newly inserted (to avoid wiping user custom formatting).
  if (!CFG.APPLY_TEMPLATE_TO_WRITTEN_ROWS) return;
  if (neededDataRows <= 0) return;

  var tr = Number(CFG.TEMPLATE_ROW_INDEX || 2);
  if (tr < 2) tr = 2;

  var neededLastRow = tr + neededDataRows - 1; // data starts at template row index
  var maxRowsBefore = sheet.getMaxRows();

  if (maxRowsBefore >= neededLastRow) return;

  var toInsert = neededLastRow - maxRowsBefore;
  sheet.insertRowsAfter(maxRowsBefore, toInsert);

  // Apply template formats & DV to ONLY the inserted rows
  var src = sheet.getRange(tr, 1, 1, colCount);
  var dst = sheet.getRange(maxRowsBefore + 1, 1, toInsert, colCount);

  src.copyTo(dst, SpreadsheetApp.CopyPasteType.PASTE_FORMAT, false);
  src.copyTo(dst, SpreadsheetApp.CopyPasteType.PASTE_DATA_VALIDATION, false);
},

  applyPostWriteFormats_: function(sheet, header, rowCount, log) {
    if (!rowCount || rowCount <= 0) return;

    var tatIdx = findHeaderIndexByOccurrence_(header, 'TAT', 1);
    if (tatIdx >= 0) {
      sheet.getRange(2, tatIdx + 1, rowCount, 1).setNumberFormat('0');
    }

    var updateStatusIdx = findHeaderIndexByOccurrence_(header, 'Update Status', 1);
    if (updateStatusIdx >= 0) {
      sheet.getRange(2, updateStatusIdx + 1, rowCount, 1).setNumberFormat('@');
    }

    var timestampStatusIdx = findHeaderIndexByOccurrence_(header, 'Timestamp Status', 1);
    if (timestampStatusIdx >= 0) {
      sheet.getRange(2, timestampStatusIdx + 1, rowCount, 1).setNumberFormat('dd/MM/yyyy hh:mm:ss');
    }

    var timestampIdx = findHeaderIndexByOccurrence_(header, 'Timestamp', 1);
    if (timestampIdx >= 0) {
      sheet.getRange(2, timestampIdx + 1, rowCount, 1).setNumberFormat('dd/MM/yyyy hh:mm:ss');
    }
  },

  ensureColumns_: function(sheet, neededCols) {
    var current = sheet.getMaxColumns();
    if (current < neededCols) {
      sheet.insertColumnsAfter(current, neededCols - current);
    }
  },

  clearData_: function(sheet, colCount) {
    var lastRow = sheet.getLastRow();
    if (lastRow <= 1) return;
    sheet.getRange(2, 1, lastRow - 1, colCount).clearContent();
  }
};


