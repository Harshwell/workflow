};


/** =============================================================================
 *  STORE REGION REPO: PartnerName -> RegionSheet (plain object map)
 *  ===========================================================================*/
var StoreRegionRepo = {
  loadPartnerToRegionMap_: function(log, forceReload) {
    var props = PropertiesService.getScriptProperties();
    var cacheKey = 'STORE_REGION_CACHE_V2';
    var cacheTsKey = 'STORE_REGION_CACHE_TS_V2';

    var now = new Date().getTime();
    var cachedTs = Number(props.getProperty(cacheTsKey) || '0');
    var cachedJson = props.getProperty(cacheKey);

    if (!forceReload && cachedJson && (now - cachedTs) < CFG.STORE_REGION_CACHE_MS) {
      try {
        var obj = JSON.parse(cachedJson);
        if (obj && typeof obj === 'object') return obj;
      } catch (e) {
        // fallthrough
      }
    }

    var ss = SpreadsheetApp.openById(CFG.STORE_REGION_SS_ID);
    var sheet = ss.getSheetByName(CFG.STORE_REGION_SHEET);
    if (!sheet) throw new Error('Store Region sheet not found: ' + CFG.STORE_REGION_SHEET);

    var lastRow = sheet.getLastRow();
    var lastCol = sheet.getLastColumn();
    if (lastRow < 3 || lastCol < 1) return {};

    var top2 = sheet.getRange(1, 1, 2, lastCol).getValues();
var row1Raw = mapToTrimStrings_(top2[0]);
var row2 = mapToTrimStrings_(top2[1]);

// Row1 often contains merged region headers, so only the first cell of a merged block has the region text.
// Fill-forward across columns so every column inside the block resolves the correct region.
var row1 = StoreRegionRepo._fillForwardRegionHeaders_(row1Raw);

var partnerCols = [];
for (var c = 0; c < lastCol; c++) {
  if (String(row2[c]).toLowerCase() === 'partner name') {
    var regionName = StoreRegionRepo._normalizeRegionSheetName_(String(row1[c] || '').trim());
    if (regionName) partnerCols.push({ colIndex1: c + 1, regionName: regionName });
  }
}



// Diagnostics: validate Store Region sheet layout is readable by this script
if (partnerCols.length === 0) {
  log.error('StoreRegion unreadable: no "Partner Name" columns detected on row 2', {
    sheet: CFG.STORE_REGION_SHEET,
    lastRow: lastRow,
    lastCol: lastCol,
    row1: row1Raw.slice(0, Math.min(row1Raw.length, 30)),
    row2: row2.slice(0, Math.min(row2.length, 30))
  });
  Audit.append_(log, { event: 'STORE_REGION_INVALID', reason: 'NO_PARTNER_NAME_COLUMNS', lastRow: lastRow, lastCol: lastCol });
} else {
  log.info('StoreRegion partner columns detected', { columns: partnerCols, lastRow: lastRow, lastCol: lastCol });
  Audit.append_(log, { event: 'STORE_REGION_DIAG', partnerCols: partnerCols.length, regions: partnerCols.map(function(x){return x.regionName;}) });
}
    var map = {}; // partnerKey -> regionName
    var conflicts = 0;

    for (var p = 0; p < partnerCols.length; p++) {
      var pc = partnerCols[p];
      var colVals = sheet.getRange(3, pc.colIndex1, lastRow - 2, 1).getValues();

      for (var r = 0; r < colVals.length; r++) {
        var pn = String(colVals[r][0] || '').trim();
        if (!pn) continue;
        var key = Norm.partnerKey_(pn);

        if (map[key] && map[key] !== pc.regionName) {
          conflicts++;
          continue;
        }
        map[key] = pc.regionName;
      }
    }

    if (conflicts > 0) {
      log.warn('StoreRegion conflicts detected (partner exists in multiple regions)', { conflicts: conflicts });
      Audit.append_(log, { event: 'STORE_REGION_CONFLICTS', count: conflicts });
    }

    var mapSize = Object.keys(map).length;
    if (mapSize === 0) {
      log.warn('StoreRegion map EMPTY (no partner rows found under Partner Name columns)', {
        sheet: CFG.STORE_REGION_SHEET,
        partnerCols: partnerCols.length,
        lastRow: lastRow
      });
      Audit.append_(log, { event: 'STORE_REGION_EMPTY', partnerCols: partnerCols.length, lastRow: lastRow });
    } else {
      // Sample up to 5 keys (for troubleshooting)
      var sampleKeys = Object.keys(map).slice(0, 5);
      log.info('StoreRegion map loaded', { partners: mapSize, sampleKeys: sampleKeys });
      Audit.append_(log, { event: 'STORE_REGION_LOADED', partners: mapSize, partnerCols: partnerCols.length });
    }

    props.setProperty(cacheKey, JSON.stringify(map));
    props.setProperty(cacheTsKey, String(now));

    return map;
  },
_fillForwardRegionHeaders_: function(row1) {
  var out = [];
  var current = '';
  for (var i = 0; i < row1.length; i++) {
    var v = String(row1[i] || '').trim();
    if (v) current = v;
    out.push(current);
  }
  return out;
},

_normalizeRegionSheetName_: function(regionName) {
  var raw = String(regionName || '').trim();
  if (!raw) return '';
  var up = raw.replace(/\s+/g, ' ').trim().toUpperCase();

  // Common canonicalization to match destination sheet names
  if (up === 'SUMATRA') return 'Sumatra';
  if (up === 'JABALNUSRA') return 'Jabalnusra';
  if (up === 'SPECIAL PROJECT') return 'Special Project';
  if (up === 'B2B') return 'B2B';
  if (up === 'NATIONAL RETAILER') return 'National Retailer';
  if (up === 'SULAWESI') return 'Sulawesi';
  if (up === 'KALIMANTAN') return 'Kalimantan';
  if (up === 'DIGI' || up === 'DIGITAL' || up === 'DIGITAL REGION') return CFG.DEST_SHEET_DIGI;

  // Title-case fallback (keeps multi-word regions readable)
  var parts = raw.replace(/\s+/g, ' ').trim().split(' ');
  for (var i = 0; i < parts.length; i++) {
    var p = parts[i];
    if (!p) continue;
    parts[i] = p.charAt(0).toUpperCase() + p.slice(1).toLowerCase();
  }
  return parts.join(' ');
},

  uniqueRegions_: function(regionMap) {
    var uniq = {};
    var out = [];
    for (var k in regionMap) {
      if (!regionMap.hasOwnProperty(k)) continue;
      var region = regionMap[k];
      if (!region) continue;
      if (!uniq[region]) {
        uniq[region] = true;
        out.push(region);
      }
    }
    return out;
  }
};


/** =============================================================================
 *  HEADER PLAN: handles duplicate headers by occurrence order
 *  ===========================================================================*/
var HeaderPlan = {
  fromHeader_: function(headerRow, expectedColumns, log) {
    var header = [];
    for (var i = 0; i < headerRow.length; i++) header.push(String(headerRow[i] || '').trim());

    // nameLower -> [indices]
    var occMap = {};
    for (var j = 0; j < header.length; j++) {
      var key = String(header[j]).toLowerCase();
      if (!occMap[key]) occMap[key] = [];
      occMap[key].push(j);
    }

    // nameLower -> usedCount
    var usedOcc = {};
    var plan = []; // expectedIndex -> sourceColIndex (0-based) or -1

    for (var e = 0; e < expectedColumns.length; e++) {
      var destName = expectedColumns[e];
      plan.push(HeaderPlan.resolveSourceIndex_(destName, occMap, usedOcc));
    }

    var missing = [];
    for (var m = 0; m < expectedColumns.length; m++) {
      if (plan[m] === -1) missing.push(expectedColumns[m]);
    }
    if (missing.length > 0) {
      log.warn('Missing expected columns in source header', { missing: missing });
      Audit.append_(log, { event: 'MISSING_COLUMNS', missing: missing.slice(0, 30) });
    }

    return new HeaderPlanInstance_(header, expectedColumns, plan, log);
  },

  resolveSourceIndex_: function(destName, occMap, usedOcc) {
    var bindings = (CFG.SOURCE_COLUMN_BINDINGS && CFG.SOURCE_COLUMN_BINDINGS[destName]) || null;
    if (bindings && bindings.length) {
      for (var i = 0; i < bindings.length; i++) {
        var rule = bindings[i] || {};
        var sourceName = String(rule.name || destName).trim();
        var key = sourceName.toLowerCase();
        var arr = occMap[key] || [];
        var pick = -1;

        if (rule.occurrence != null) {
          var occ = Number(rule.occurrence || 1);
          if (occ >= 1 && typeof arr[occ - 1] === 'number') pick = arr[occ - 1];
        } else {
          var used = usedOcc[key] || 0;
          if (typeof arr[used] === 'number') pick = arr[used];
          usedOcc[key] = used + 1;
        }

        if (pick >= 0) return pick;
      }
      return -1;
    }

    var k = String(destName || '').toLowerCase();
    var sameArr = occMap[k] || [];
    var sameUsed = usedOcc[k] || 0;
    var samePick = (typeof sameArr[sameUsed] === 'number') ? sameArr[sameUsed] : -1;
    usedOcc[k] = sameUsed + 1;
    return samePick;
  }
};

function HeaderPlanInstance_(header, expected, indexPlan, log) {
  this.header = header;
  this.expected = expected;
  this.indexPlan = indexPlan;
  this.log = log;
}

/**
 * Returns the FIRST occurrence of a column (even if duplicated).
 */
HeaderPlanInstance_.prototype.getFirst_ = function(row, colName) {
  var idx = indexOf_(this.expected, colName);
  if (idx < 0) return '';
  var srcIdx = this.indexPlan[idx];
  return (srcIdx >= 0) ? row[srcIdx] : '';
};

/**
 * Builds destination row in expected order, with translated Last Status and PIC appended.
 */
HeaderPlanInstance_.prototype.buildDestRow_ = function(row, translatedLastStatus, pic) {
  var out = [];
  for (var i = 0; i < this.expected.length; i++) {
    var colName = this.expected[i];
    if (colName === 'Last Status') {
      out.push(translatedLastStatus);
      continue;
    }

    var srcIdx = this.indexPlan[i];
    var value = srcIdx >= 0 ? row[srcIdx] : '';

    if (colName === 'TAT') {
      value = normalizeTatValue_(value);
    }

    out.push(value);
  }
  out.push(pic);
  return out;
};


