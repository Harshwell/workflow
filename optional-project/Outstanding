var COMPILED_CFG = (function(cfg) {
  function partnerKeyLocal_(s) {
    return String(s || '').trim().toLowerCase().replace(/\s+/g, ' ');
  }

  function toLowerList_(list) {
    var out = [];
    for (var i = 0; i < list.length; i++) {
      out.push(String(list[i] || '').toLowerCase());
    }
    return out;
  }

  var digiPartnerLookup = {};
  for (var i = 0; i < cfg.DIGI_PARTNERS.length; i++) {
    digiPartnerLookup[partnerKeyLocal_(cfg.DIGI_PARTNERS[i])] = true;
  }

  var excludedStatusLookup = {};
  var excluded = cfg.EXCLUDED_LAST_STATUS_TEXTS || [];
  for (var j = 0; j < excluded.length; j++) {
    excludedStatusLookup[String(excluded[j] || '').trim().toLowerCase()] = true;
  }

  return {
    DIGI_PARTNER_LOOKUP: digiPartnerLookup,
    MIDDLE_SC_KEYWORDS_LOWER: {
      Farhan: toLowerList_(cfg.MIDDLE_SC_KEYWORDS.Farhan || []),
      Meilani: toLowerList_(cfg.MIDDLE_SC_KEYWORDS.Meilani || []),
      Ivan: toLowerList_(cfg.MIDDLE_SC_KEYWORDS.Ivan || [])
    },
    EXCLUDED_STATUS_LOOKUP: excludedStatusLookup
  };
})(CFG);

function validateCfg_() {
  var required = [
    'OVERVIEW_CLAIM_SS_ID',
    'CLAIM_OUTSTANDING_SS_ID',
    'STORE_REGION_SS_ID',
    'STORE_REGION_SHEET',
    'DEST_SHEET_DIGI',
    'EXPECTED_COLUMNS',
    'SOURCE_SHEETS'
  ];
  for (var i = 0; i < required.length; i++) {
    var key = required[i];
    if (!CFG[key] || (CFG[key].length !== undefined && CFG[key].length === 0)) {
      throw new Error('Invalid CFG: required key is empty -> ' + key);
    }
  }

  var seen = {};
  for (var j = 0; j < CFG.SOURCE_SHEETS.length; j++) {
    var sheetName = String(CFG.SOURCE_SHEETS[j] || '').trim();
    if (!sheetName) throw new Error('Invalid CFG: SOURCE_SHEETS contains empty value.');
    if (seen[sheetName]) throw new Error('Invalid CFG: duplicate SOURCE_SHEETS entry -> ' + sheetName);
    seen[sheetName] = true;
  }
}


