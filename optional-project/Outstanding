function install() {
  validateCfg_();
  var runId = RunIds.newId();
  var log = LoggerFactory.scoped(runId, 'install', null);
  log.info('Start install', null);

  withLock_(CFG.LOCK_TIMEOUT_MS, function() {
    SysSheets.ensureAll(log);
    DestSheets.ensureSpecialSheets(log);
    Triggers.ensureTriggers(log);
    Menus.ensureMenu_();
  });

  log.info('Install complete', null);
}


function runNow() {
  startRun_({
    scope: 'runNow',
    manual: true,
    forceFresh: false,
    ignoreHourKey: !!CFG.ALLOW_MANUAL_RERUN_SAME_HOUR
  });
  runWorker(); // best-effort immediate drain
}

function runNowFresh() {
  startRun_({
    scope: 'runNowFresh',
    manual: true,
    forceFresh: !!CFG.RESET_SYSTEM_SHEETS_ON_MANUAL_FRESH,
    ignoreHourKey: true
  });
  runWorker(); // best-effort immediate drain
}

/**
 * Debug helper: validates Store Region sheet readability and prints diagnostics.
 * Safe to run manually.
 */
function debugStoreRegion_() {
  var runId = RunIds.newId();
  var log = LoggerFactory.scoped(runId, 'debugStoreRegion', null);
  SysSheets.ensureAll(log);
  try {
    var map = StoreRegionRepo.loadPartnerToRegionMap_(log, true);
    log.info('debugStoreRegion done', { mapSize: Object.keys(map).length });
    Audit.append_(log, { event: 'DEBUG_STORE_REGION_DONE', mapSize: Object.keys(map).length });
  } catch (e) {
    log.error('debugStoreRegion failed', { err: String(e), stack: e && e.stack ? String(e.stack) : '' });
    Audit.append_(log, { event: 'DEBUG_STORE_REGION_FAILED', err: String(e) });
    throw e;
  }
}

/**
 * Trigger hourly: create a new run and enqueue tasks (idempotent per hour).
 */
function enqueueHourlyRun() {
  startRun_({
    scope: 'enqueueHourlyRun',
    manual: false,
    forceFresh: false,
    ignoreHourKey: false
  });
}

function resetSystemState() {
  var runId = RunIds.newId();
  var log = LoggerFactory.scoped(runId, 'resetSystemState', null);

  withLock_(CFG.LOCK_TIMEOUT_MS, function() {
    SysSheets.ensureAll(log);
    SystemMaintenance.resetSystemState_(log, { clearCircuitBreaker: true });
  });

  log.warn('System state reset complete', null);
}

function startRun_(opts) {
  validateCfg_();
  opts = opts || {};

  var runId = RunIds.newId();
  var scope = opts.scope || 'startRun';
  var log = LoggerFactory.scoped(runId, scope, null);

  if (!opts.forceFresh && CircuitBreaker.isOpen_()) {
    log.warn('Circuit breaker OPEN; skip enqueue', null);
    Audit.append_(log, { event: 'CB_OPEN_SKIP_ENQUEUE' });
    return;
  }

  withLock_(CFG.LOCK_TIMEOUT_MS, function() {
    SysSheets.ensureAll(log);
    SystemMaintenance.beforeNewRun_(opts, log);

    var existing = RunStore.getLatestActiveRun_();
    if (existing && !QueueStore.isRunDrained_(existing.runId)) {
      log.warn('Existing run still active; skip enqueue', {
        existingRunId: existing.runId,
        existingStatus: existing.status
      });
      Audit.append_(log, {
        event: 'ACTIVE_RUN_SKIP_ENQUEUE',
        existingRunId: existing.runId,
        existingStatus: existing.status
      });
      return;
    }

    var hourKey = TimeUtil.hourKey_(new Date());
    if (!opts.ignoreHourKey && RunStore.hasRunForHour_(hourKey)) {
      log.info('Run for this hour already exists; skip enqueue', { hourKey: hourKey });
      Audit.append_(log, { event: 'DUP_HOUR_SKIP', hourKey: hourKey });
      return;
    }

    var regionMap = StoreRegionRepo.loadPartnerToRegionMap_(log); // key -> region
    var regions = StoreRegionRepo.uniqueRegions_(regionMap);
    DestSheets.ensureRegionSheets(log, regions);

    var run = {
      runId: runId,
      hourKey: hourKey,
      status: 'ENQUEUED',
      createdAt: new Date(),
      totalTasks: 0,
      doneTasks: 0,
      failedTasks: 0,
      notes: opts.forceFresh ? 'Fresh run' : ''
    };
    RunStore.createRun_(run);

    Staging.resetForRun_(runId, log);

    var tasks = QueueBuilder.buildTasks_(runId, CFG.SOURCE_SHEETS, CFG.TASK_PAGE_SIZE, log);
    QueueStore.enqueueTasks_(tasks, log);

    RunStore.updateRun_(runId, { totalTasks: tasks.length });
    Audit.append_(log, {
      event: 'ENQUEUED',
      tasks: tasks.length,
      hourKey: hourKey,
      manual: !!opts.manual,
      forceFresh: !!opts.forceFresh
    });

    log.info('Enqueue complete', {
      tasks: tasks.length,
      hourKey: hourKey,
      manual: !!opts.manual,
      forceFresh: !!opts.forceFresh
    });
  });
}

/**
 * Worker trigger: process some tasks; finalize if queue drained.
 */
function runWorker() {
  validateCfg_();
  var runId = RunIds.newId();
  var log = LoggerFactory.scoped(runId, 'runWorker', null);

  if (CircuitBreaker.isOpen_()) {
    log.warn('Circuit breaker OPEN; skip worker', null);
    Audit.append_(log, { event: 'CB_OPEN_SKIP_WORKER' });
    return;
  }

  withLock_(CFG.LOCK_TIMEOUT_MS, function() {
    SysSheets.ensureAll(log);

    var activeRun = RunStore.getLatestActiveRun_();
    if (!activeRun) {
      log.info('No active run; nothing to do', null);
      return;
    }

    var targetRunId = activeRun.runId;
    log.info('Worker processing', { targetRunId: targetRunId });

    QueueStore.recoverStaleInProgress_(targetRunId, log);

    var tasks = QueueStore.dequeueAndMarkInProgress_(targetRunId, CFG.WORKER_MAX_TASKS_PER_RUN, log);
    if (tasks.length === 0) {
      if (QueueStore.isRunDrained_(targetRunId)) {
        finalizeRunSafely_(targetRunId, log);
      } else {
        log.info('No runnable tasks yet (retry scheduled or in progress)', null);
      }
      return;
    }

    var done = 0;
    var failed = 0;

    for (var i = 0; i < tasks.length; i++) {
      var task = tasks[i];
      var taskLog = LoggerFactory.scoped(targetRunId, 'task', { taskId: task.taskId, sourceSheet: task.sourceSheet });

      try {
        TaskProcessor.processTask_(targetRunId, task, taskLog);
        QueueStore.markDone_(task, taskLog);
        done++;
        CircuitBreaker.onSuccess_();
      } catch (err) {
        failed++;
        QueueStore.markFailedOrRetry_(task, err, taskLog);
      }
    }

    RunStore.bumpProgress_(targetRunId, { doneInc: done, failedInc: failed });

    if (QueueStore.isRunDrained_(targetRunId)) {
      finalizeRunSafely_(targetRunId, log);
    }

    log.info('Worker batch complete', { targetRunId: targetRunId, done: done, failed: failed });
  });
}

function finalizeRunSafely_(targetRunId, log) {
  try {
    Finalizer.finalizeRun_(targetRunId, log);
    var status = RunStore.computeTerminalStatus_(targetRunId);
    RunStore.updateRun_(targetRunId, { status: status, notes: 'Finalized' });
    Audit.append_(log, { event: 'FINALIZED', runId: targetRunId, status: status });
    return true;
  } catch (e) {
    log.error('Finalize failed', { err: String(e), stack: e && e.stack ? String(e.stack) : '' });
    RunStore.updateRun_(targetRunId, { status: 'FAILED', notes: 'Finalize failed: ' + String(e) });
    Audit.append_(log, { event: 'FINALIZE_FAILED', runId: targetRunId, err: String(e) });
    CircuitBreaker.onError_();
    return false;
  }
}

