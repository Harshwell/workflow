function _validateConfig_() {
  var requiredText = [
    "SCRIPT_VERSION",
    "FLOW_NAME",
    "DEST_SPREADSHEET_ID",
    "OVERVIEW_SHEET",
    "UNMAPPED_SHEET_NAME",
  ];
  for (var i = 0; i < requiredText.length; i++) {
    var key = requiredText[i];
    if (!String(CONFIG[key] || "").trim()) {
      throw new Error('Invalid CONFIG: "' + key + '" is required.');
    }
  }
  if (!CONFIG.SOURCE_SHEETS || !CONFIG.SOURCE_SHEETS.length) {
    throw new Error("Invalid CONFIG: SOURCE_SHEETS must not be empty.");
  }
}

