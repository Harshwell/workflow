  dedupeAtKey: 'SALVAGE_LAST_PROCESSED_AT_ISO',
};

function validateSalvageConfig_() {
  const checks = [
    ['gmail.labelName', SALVAGE_CONFIG.gmail && SALVAGE_CONFIG.gmail.labelName],
    ['gmail.from', SALVAGE_CONFIG.gmail && SALVAGE_CONFIG.gmail.from],
    ['gmail.subject', SALVAGE_CONFIG.gmail && SALVAGE_CONFIG.gmail.subject],
    ['target.spreadsheetId', SALVAGE_CONFIG.target && SALVAGE_CONFIG.target.spreadsheetId],
    ['target.sheetName', SALVAGE_CONFIG.target && SALVAGE_CONFIG.target.sheetName],
    ['log.spreadsheetId', SALVAGE_CONFIG.log && SALVAGE_CONFIG.log.spreadsheetId],
    ['log.sheetName', SALVAGE_CONFIG.log && SALVAGE_CONFIG.log.sheetName],
    ['runtime.duplicateThreadWindowHours', SALVAGE_CONFIG.runtime && SALVAGE_CONFIG.runtime.duplicateThreadWindowHours],
  ];
  for (let i = 0; i < checks.length; i += 1) {
    if (!String(checks[i][1] || '').trim()) {
      throw new Error('Invalid SALVAGE_CONFIG: missing ' + checks[i][0]);
    }
  }
}

function wasThreadProcessedRecently_(threadId) {
  const prevThreadId = SALVAGE_RUNTIME.props.getProperty(SALVAGE_RUNTIME.dedupeThreadKey);
  if (!prevThreadId || prevThreadId !== String(threadId || '')) return false;

  const prevAtIso = SALVAGE_RUNTIME.props.getProperty(SALVAGE_RUNTIME.dedupeAtKey);
  const prevAt = prevAtIso ? new Date(prevAtIso) : null;
  if (!(prevAt && !Number.isNaN(prevAt.getTime()))) return false;

  const windowHours = Number(SALVAGE_CONFIG.runtime.duplicateThreadWindowHours || 0);
  if (!(windowHours > 0)) return false;

  const cutoffMs = Date.now() - (windowHours * 60 * 60 * 1000);
  return prevAt.getTime() >= cutoffMs;
  return !!(prevAt && !Number.isNaN(prevAt.getTime()));
}

function rememberProcessedThread_(threadId) {
  SALVAGE_RUNTIME.props.setProperties({
    SALVAGE_LAST_PROCESSED_THREAD_ID: String(threadId || ''),
    SALVAGE_LAST_PROCESSED_AT_ISO: new Date().toISOString(),
  });
}

/**
 * Run once manually after pasting the script.
 * Creates/recreates the daily trigger and prepares the log sheet layout.
 */
function setupSalvageAutomation() {
  validateSalvageConfig_();
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);
  try {
    ensureLogSheetLayout_();
    ensureQueuedSalvageLabelAndFilter_();
    deleteTriggersByHandler_('runQueuedSalvage');

    ScriptApp.newTrigger('runQueuedSalvage')
      .timeBased()
      .everyDays(1)
      .atHour(9)
      .inTimezone(SALVAGE_CONFIG.scriptTimeZone)
      .create();
  } finally {
    lock.releaseLock();
  }
}

/**
 * Optional helper to remove the installed daily trigger.
 */
function removeSalvageAutomationTrigger() {
  deleteTriggersByHandler_('runQueuedSalvage');
}

/**
 * Main production job.
 */
function runQueuedSalvage() {
  validateSalvageConfig_();
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(30000)) {
    throw new Error('Another salvage job is currently running. Please retry later.');
  }

  const ctx = createRunContext_();
  let tempFileId = null;
  let processedThread = null;

  try {
    ensureLogSheetLayout_();
    resetLogDetails_();
    updateProgress_(0, 'Initializing');

    logStage_(ctx, {
      stage: 'INIT',
      segment: 'start',
      status: 'RUNNING',
      severity: 'INFO',
      notes: 'Salvage job started.',
    });

    const validationStart = Date.now();
    const env = validateEnvironment_();
    logStage_(ctx, {
      stage: 'INIT',
      segment: 'validate_environment',
      durationMs: Date.now() - validationStart,
      status: 'OK',
      severity: 'INFO',
      metrics: safeJson_(env),
      notes: 'Environment validated.',
    });

    updateProgress_(10, 'Searching queued email');
    const emailStart = Date.now();
    const mailBundle = findLatestEligibleEmail_();
    if (!mailBundle) {
      updateProgress_(100, 'No eligible email found');
      logStage_(ctx, {
        stage: 'EMAIL',
        segment: 'find_latest',
        durationMs: Date.now() - emailStart,
        status: 'NO_DATA',
        severity: 'WARN',
        notes: 'No eligible email found inside the QUEUED_SALVAGE label.',
      });
      writeTargetRunTimestamp_();
      return;
    }

    processedThread = mailBundle.thread;
    ctx.emailFrom = mailBundle.message.getFrom();
    ctx.emailSubject = mailBundle.message.getSubject();
    ctx.threadId = mailBundle.thread.getId();
    ctx.attachmentName = mailBundle.attachment.getName();
    ctx.attachmentSize = mailBundle.attachment.getSize();
    ctx.attachmentType = mailBundle.attachment.getContentType();

    if (wasThreadProcessedRecently_(ctx.threadId)) {
      updateProgress_(100, 'Skipped duplicate thread');
      logStage_(ctx, {
        stage: 'EMAIL',
        segment: 'duplicate_guard',
        durationMs: Date.now() - emailStart,
        status: 'SKIPPED',
        severity: 'WARN',
        notes: 'Skipped because thread was already processed previously.',
      });
      return;
    }

    logStage_(ctx, {
      stage: 'EMAIL',
      segment: 'find_latest',
      durationMs: Date.now() - emailStart,
      status: 'OK',
      severity: 'INFO',
      notes: 'Eligible email and attachment selected.',
      metrics: safeJson_({
        threadDate: mailBundle.message.getDate(),
        threadCountScanned: mailBundle.meta.threadCountScanned,
        matchedCount: mailBundle.meta.matchedCount,
      }),
    });

    updateProgress_(25, 'Converting XLSX into temp sheet');
    const convertStart = Date.now();
    tempFileId = convertAttachmentToTempSpreadsheet_(mailBundle.attachment);
    logStage_(ctx, {
      stage: 'TEMP_FILE',
      segment: 'convert_attachment',
      durationMs: Date.now() - convertStart,
      status: 'OK',
      severity: 'INFO',
      notes: 'Attachment converted to temporary spreadsheet.',
      metrics: safeJson_({ tempFileId: tempFileId }),
    });

    updateProgress_(40, 'Reading source data');
    const sourceStart = Date.now();
    const sourceSnapshot = readSourceSnapshot_(tempFileId);
    ctx.rawRows = sourceSnapshot.rawRows;
    logStage_(ctx, {
      stage: 'SOURCE',
      segment: 'read_snapshot',
      durationMs: Date.now() - sourceStart,
      rawRows: sourceSnapshot.rawRows,
      status: 'OK',
      severity: sourceSnapshot.duplicateClaimNumbers.length ? 'WARN' : 'INFO',
      notes: sourceSnapshot.duplicateClaimNumbers.length
        ? 'Source loaded with duplicate Claim Number(s); last occurrence wins.'
        : 'Source loaded successfully.',
      metrics: safeJson_({
        availableSheets: sourceSnapshot.availableSheets,
        selectedSheetName: sourceSnapshot.sheetName,
        sourceHeaderRow: sourceSnapshot.headerRow,
        sourceHeaders: sourceSnapshot.headers,
        resolvedSourceColumns: sourceSnapshot.resolvedColumnMap,
        sampleClaims: sourceSnapshot.sampleClaims,
        duplicateClaimNumbers: sourceSnapshot.duplicateClaimNumbers.slice(0, 20),
      }),
    });

    if (sourceSnapshot.rawRows === 0) {
      throw new Error('Source spreadsheet is empty; target sheet was not updated to avoid false missing-claim markings.');
    }

    updateProgress_(55, 'Inspecting source/target bindings');
    const inspectStart = Date.now();
    const targetSnapshot = inspectTargetSnapshot_();
    logStage_(ctx, {
      stage: 'PRECHECK',
      segment: 'inspect_bindings',
      durationMs: Date.now() - inspectStart,
      rawRows: sourceSnapshot.rawRows,
      status: 'OK',
      severity: targetSnapshot.blankGapCount > 0 ? 'WARN' : 'INFO',
      notes: targetSnapshot.blankGapCount > 0
        ? 'Bindings verified. Target sheet contains blank gaps that were preserved without reordering rows.'
        : 'Bindings verified for source and target sheets.',
      metrics: safeJson_({
        sourceSheetName: sourceSnapshot.sheetName,
        sourceHeaderRow: sourceSnapshot.headerRow,
        sourceHeaders: sourceSnapshot.headers,
        resolvedSourceColumns: sourceSnapshot.resolvedColumnMap,
        sourceSampleClaims: sourceSnapshot.sampleClaims,
        targetSheetName: targetSnapshot.sheetName,
        targetHeaderRow: targetSnapshot.headerRow,
        targetHeaders: targetSnapshot.headers,
        resolvedTargetColumns: targetSnapshot.columnMap,
        targetClaimRows: targetSnapshot.claimRowCount,
        blankGapCount: targetSnapshot.blankGapCount,
        blankGapSamples: targetSnapshot.blankGapSamples,
        duplicateClaimCount: targetSnapshot.duplicateClaimCount,
        duplicateClaimSamples: targetSnapshot.duplicateClaimSamples,
        targetSampleClaims: targetSnapshot.sampleClaims,
      }),
    });

    if (targetSnapshot.duplicateClaimCount > 0) {
      throwDuplicateTargetError_(targetSnapshot);
    }

    updateProgress_(65, 'Upserting into target sheet');
    const syncStart = Date.now();
    const syncResult = syncTargetSheet_(sourceSnapshot, targetSnapshot);
    ctx.opsUpdated = syncResult.updatedCount;
    ctx.subInserted = syncResult.insertedCount;
    logStage_(ctx, {
      stage: 'TARGET',
      segment: 'upsert_salvage',
      durationMs: Date.now() - syncStart,
      rawRows: sourceSnapshot.rawRows,
      opsUpdated: syncResult.updatedCount,
      subInserted: syncResult.insertedCount,
      status: 'OK',
      severity: (syncResult.missingExistingCount > 0 || syncResult.blankGapCount > 0) ? 'WARN' : 'INFO',
      notes: 'Target sheet synchronized.',
      metrics: safeJson_({
        missingExistingCount: syncResult.missingExistingCount,
        restoredCount: syncResult.restoredCount,
        targetHeaderRow: syncResult.targetHeaderRow,
        targetSheetName: syncResult.targetSheetName,
        existingClaimRowsBeforeRun: syncResult.existingClaimRowsBeforeRun,
        blankGapCount: syncResult.blankGapCount,
        blankGapSamples: syncResult.blankGapSamples,
        duplicateTargetClaimCount: syncResult.duplicateTargetClaimCount,
        duplicateTargetClaimSamples: syncResult.duplicateTargetClaimSamples,
        finalRowCount: syncResult.finalRowCount,
      }),
    });

    updateProgress_(78, 'Verifying target write');
    const verifyStart = Date.now();
    const verifyResult = verifyPostSync_(sourceSnapshot, targetSnapshot);
    logStage_(ctx, {
      stage: 'POSTCHECK',
      segment: 'verify_write',
      durationMs: Date.now() - verifyStart,
      rawRows: sourceSnapshot.rawRows,
      opsUpdated: syncResult.updatedCount,
      subInserted: syncResult.insertedCount,
      status: 'OK',
      severity: verifyResult.blankGapCount > 0 ? 'WARN' : 'INFO',
      notes: 'Post-sync verification passed.',
      metrics: safeJson_(verifyResult),
    });

    updateProgress_(88, 'Cleaning temporary file');
    const cleanupStart = Date.now();
    trashTempFile_(tempFileId);
    tempFileId = null;
    logStage_(ctx, {
      stage: 'CLEANUP',
      segment: 'trash_temp_file',
      durationMs: Date.now() - cleanupStart,
      status: 'OK',
      severity: 'INFO',
      notes: 'Temporary spreadsheet moved to trash.',
    });

    updateProgress_(95, 'Trashing processed email');
    const emailCleanupStart = Date.now();
    processedThread.moveToTrash();
    rememberProcessedThread_(ctx.threadId);
    logStage_(ctx, {
      stage: 'CLEANUP',
      segment: 'trash_email_thread',
      durationMs: Date.now() - emailCleanupStart,
      status: 'OK',
      severity: 'INFO',
      notes: 'Processed email thread moved to trash.',
    });

    writeTargetRunTimestamp_();
    updateProgress_(100, 'Completed');
    logStage_(ctx, {
      stage: 'DONE',
      segment: 'finish',
      durationMs: Date.now() - ctx.runStartedMs,
      rawRows: sourceSnapshot.rawRows,
      opsUpdated: syncResult.updatedCount,
      subInserted: syncResult.insertedCount,
      status: 'SUCCESS',
      severity: 'INFO',
      notes: 'Salvage job finished successfully.',
      metrics: safeJson_({
        runId: ctx.runId,
        totalDurationMs: Date.now() - ctx.runStartedMs,
      }),
    });
  } catch (error) {
    updateProgress_(100, 'Failed');
    logStage_(ctx, {
      stage: 'ERROR',
      segment: 'exception',
      durationMs: Date.now() - ctx.runStartedMs,
      rawRows: ctx.rawRows,
      opsUpdated: ctx.opsUpdated,
      subInserted: ctx.subInserted,
      status: 'FAILED',
      severity: 'ERROR',
      error: stringifyError_(error),
      notes: tempFileId
        ? 'Temp file intentionally kept for debugging because the run failed.'
        : 'Run failed before or after temp-file cleanup.',
      metrics: safeJson_({
        runId: ctx.runId,
        tempFileId: tempFileId,
      }),
    });
    try {
      writeTargetRunFailureNotice_(error);
    } catch (timestampError) {
      Logger.log('Failed to write Salvage failure notice after error: ' + stringifyError_(timestampError));
    }
    throw error;
  } finally {
    lock.releaseLock();
  }
}

