      status: 'SUCCESS',
      severity: (diffPreview.missingExistingCount > 0 || diffPreview.restoreCount > 0 || diffPreview.insertCount > 0) ? 'WARN' : 'INFO',
      notes: 'Dry-run diff preview completed. No target write, no email trash.',
      metrics: safeJson_(diffPreview),
    });

    return diffPreview;
  } catch (error) {
    updateProgress_(100, 'Preview failed');
    logStage_(ctx, {
      stage: 'PREVIEW',
      segment: 'exception',
      status: 'FAILED',
      severity: 'ERROR',
      error: stringifyError_(error),
      notes: tempFileId
        ? 'Preview failed. Temp file intentionally kept for debugging.'
        : 'Preview failed before temp file creation or after cleanup.',
      metrics: safeJson_({ tempFileId: tempFileId, runId: ctx.runId }),
    });
    throw error;
  } finally {
    lock.releaseLock();
  }
}

function createRunContext_() {
  const now = new Date();
  return {
