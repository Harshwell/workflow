}

function buildProgressBar_(percent) {
  const total = SALVAGE_CONFIG.progress.blocks;
  const filled = Math.round((Math.max(0, Math.min(100, percent)) / 100) * total);
  return repeatChar_('█', filled) + repeatChar_('░', total - filled);
}

function deleteTriggersByHandler_(functionName) {
  ScriptApp.getProjectTriggers().forEach(function(trigger) {
    if (trigger.getHandlerFunction() === functionName) {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}

function detectHeaderRow_(sheet, aliasGroups, maxRowsToScan) {
  const rowsToScan = Math.min(Math.max(sheet.getLastRow(), 1), maxRowsToScan || 10);
  const colsToScan = Math.max(sheet.getLastColumn(), 1);
  const scanValues = sheet.getRange(1, 1, rowsToScan, colsToScan).getDisplayValues();

  let best = null;
  for (let r = 0; r < scanValues.length; r += 1) {
    const normalizedCells = scanValues[r].map(normalizeHeader_).filter(Boolean);
    const cellSet = {};
    normalizedCells.forEach(function(value) {
      cellSet[value] = true;
    });

    let score = 0;
    aliasGroups.forEach(function(group) {
      const found = group.some(function(alias) {
        return !!cellSet[normalizeHeader_(alias)];
      });
      if (found) score += 1;
    });

    if (!best || score > best.score) {
      best = { headerRow: r + 1, score: score };
    }
  }

  if (!best || best.score === 0) {
    return null;
  }
  return best;
}

function buildHeaderMap_(sheet, headerRow) {
  const lastCol = Math.max(sheet.getLastColumn(), 1);
  const headers = sheet.getRange(headerRow, 1, 1, lastCol).getDisplayValues()[0];
  const map = {};

  headers.forEach(function(header, idx) {
    const normalized = normalizeHeader_(header);
    if (normalized && !map[normalized]) {
      map[normalized] = idx + 1;
    }
  });

  return map;
}

function resolveAliasMap_(headerMap, aliasMap, mapName) {
  const resolved = {};
  const missing = [];

  Object.keys(aliasMap).forEach(function(logicalName) {
    const aliases = aliasMap[logicalName];
    const matchedAlias = aliases.find(function(alias) {
      return !!headerMap[normalizeHeader_(alias)];
    });

    if (!matchedAlias) {
      missing.push(logicalName + ' => [' + aliases.join(' | ') + ']');
      return;
    }

    resolved[logicalName] = headerMap[normalizeHeader_(matchedAlias)];
  });

  if (missing.length) {
    throw new Error(
      'Missing ' + mapName + ' header(s): ' + missing.join('; ')
    );
  }

  return resolved;
}

function normalizeHeader_(value) {
  return String(value || '')
    .replace(/[\r\n]+/g, ' ')
    .replace(/[→➜➝⟶]/g, '->')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
}

function normalizeKey_(value) {
  return String(value === null || value === undefined ? '' : value)
    .replace(/\s+/g, '')
    .trim()
    .toLowerCase();
}

function ensureSheetHasRows_(sheet, requiredLastRow) {
  const currentMax = sheet.getMaxRows();
  if (currentMax < requiredLastRow) {
    sheet.insertRowsAfter(currentMax, requiredLastRow - currentMax);
  }
}

function ensureSheetHasColumns_(sheet, requiredLastCol) {
  const currentMax = sheet.getMaxColumns();
  if (currentMax < requiredLastCol) {
    sheet.insertColumnsAfter(currentMax, requiredLastCol - currentMax);
  }
}

function createEmptyRow_(width) {
  const row = [];
  for (let i = 0; i < width; i += 1) {
    row.push('');
  }
  return row;
}

function stringifyError_(error) {
  if (!error) return '';
  if (typeof error === 'string') return error;
  const message = error.message || String(error);
  const stack = error.stack ? (' | ' + error.stack) : '';
  return message + stack;
}

function valueOrBlank_(value) {
  return value === undefined || value === null ? '' : value;
}

function repeatChar_(char, times) {
  let output = '';
  for (let i = 0; i < times; i += 1) {
    output += char;
  }
  return output;
}
