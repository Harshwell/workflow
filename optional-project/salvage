function diagnoseQueuedSalvage() {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(30000)) {
    throw new Error('Another salvage job is currently running. Please retry later.');
  }

  const ctx = createRunContext_();
  let tempFileId = null;
  try {
    ensureLogSheetLayout_();
    resetLogDetails_();
    updateProgress_(0, 'Diagnosing');

    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'start',
      status: 'RUNNING',
      severity: 'INFO',
      notes: 'Diagnostic run started. No target write, no email trash.',
    });

    const env = validateEnvironment_();
    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'validate_environment',
      status: 'OK',
      severity: 'INFO',
      metrics: safeJson_(env),
      notes: 'Environment validated.',
    });

    const mailBundle = findLatestEligibleEmail_();
    if (!mailBundle) {
      updateProgress_(100, 'No eligible email found');
      logStage_(ctx, {
        stage: 'DIAG',
        segment: 'find_latest',
        status: 'NO_DATA',
        severity: 'WARN',
        notes: 'No eligible email found inside the QUEUED_SALVAGE label.',
      });
      return;
    }

    ctx.emailFrom = mailBundle.message.getFrom();
    ctx.emailSubject = mailBundle.message.getSubject();
    ctx.threadId = mailBundle.thread.getId();
    ctx.attachmentName = mailBundle.attachment.getName();
    ctx.attachmentSize = mailBundle.attachment.getSize();
    ctx.attachmentType = mailBundle.attachment.getContentType();

    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'find_latest',
      status: 'OK',
      severity: 'INFO',
      notes: 'Eligible email and attachment selected.',
      metrics: safeJson_({
        threadDate: mailBundle.message.getDate(),
        threadCountScanned: mailBundle.meta.threadCountScanned,
        matchedCount: mailBundle.meta.matchedCount,
        selectedAttachmentName: ctx.attachmentName,
      }),
    });

    tempFileId = convertAttachmentToTempSpreadsheet_(mailBundle.attachment);
    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'convert_attachment',
      status: 'OK',
      severity: 'INFO',
      notes: 'Attachment converted to temporary spreadsheet.',
      metrics: safeJson_({ tempFileId: tempFileId }),
    });

    const sourceSnapshot = readSourceSnapshot_(tempFileId);
    const targetSnapshot = inspectTargetSnapshot_();

    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'inspect_bindings',
      rawRows: sourceSnapshot.rawRows,
      status: 'OK',
      severity: targetSnapshot.blankGapCount > 0 ? 'WARN' : 'INFO',
      notes: 'Diagnostic binding snapshot generated.',
      metrics: safeJson_({
        sourceSpreadsheetId: tempFileId,
        sourceSheetName: sourceSnapshot.sheetName,
        sourceHeaderRow: sourceSnapshot.headerRow,
        sourceHeaders: sourceSnapshot.headers,
        resolvedSourceColumns: sourceSnapshot.resolvedColumnMap,
        sourceSampleClaims: sourceSnapshot.sampleClaims,
        duplicateClaimNumbers: sourceSnapshot.duplicateClaimNumbers.slice(0, 20),
        targetSpreadsheetId: targetSnapshot.spreadsheetId,
        targetSpreadsheetName: targetSnapshot.spreadsheetName,
        targetSheetName: targetSnapshot.sheetName,
        targetHeaderRow: targetSnapshot.headerRow,
        targetHeaders: targetSnapshot.headers,
        resolvedTargetColumns: targetSnapshot.columnMap,
        targetClaimRows: targetSnapshot.claimRowCount,
        blankGapCount: targetSnapshot.blankGapCount,
        blankGapSamples: targetSnapshot.blankGapSamples,
        duplicateClaimCount: targetSnapshot.duplicateClaimCount,
        duplicateClaimSamples: targetSnapshot.duplicateClaimSamples,
        targetSampleClaims: targetSnapshot.sampleClaims,
      }),
    });

    updateProgress_(100, 'Diagnostic completed');
    if (targetSnapshot.duplicateClaimCount > 0) {
      throwDuplicateTargetError_(targetSnapshot);
    }

    updateProgress_(100, 'Diagnostic completed');
    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'finish',
      rawRows: sourceSnapshot.rawRows,
      status: 'SUCCESS',
      severity: 'INFO',
      notes: 'Diagnostic run completed. No target write, no email trash.',
    });
  } catch (error) {
    updateProgress_(100, 'Diagnostic failed');
    logStage_(ctx, {
      stage: 'DIAG',
      segment: 'exception',
      status: 'FAILED',
      severity: 'ERROR',
      error: stringifyError_(error),
      notes: tempFileId
        ? 'Diagnostic failed. Temp file intentionally kept for debugging.'
        : 'Diagnostic failed before temp file creation or after cleanup.',
      metrics: safeJson_({ tempFileId: tempFileId, runId: ctx.runId }),
    });
    throw error;
  } finally {
    lock.releaseLock();
  }
}


