    runStartedMs: Date.now(),
    runId: Utilities.formatDate(now, SALVAGE_CONFIG.scriptTimeZone, "yyyyMMdd'T'HHmmss") + '_' + Utilities.getUuid().slice(0, 8),
    emailFrom: '',
    emailSubject: '',
    threadId: '',
    attachmentName: '',
    attachmentSize: '',
    attachmentType: '',
    rawRows: '',
    opsUpdated: '',
    subInserted: '',
  };
}

function validateEnvironment_() {
  const gmailRouting = ensureQueuedSalvageLabelAndFilter_();
  const label = gmailRouting.label;

  const targetSs = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
