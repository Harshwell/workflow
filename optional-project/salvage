function ensureQueuedSalvageLabelAndFilter_() {
  const label = ensureGmailLabel_(SALVAGE_CONFIG.gmail.labelName);
  const labelId = label.getId();
  const desiredFilter = buildManagedGmailFilterDefinition_(labelId);
  let filterAction = 'disabled';
  let filterId = '';
  let filterError = '';

  if (SALVAGE_CONFIG.gmail.managedFilterEnabled) {
    try {
      const managedFilters = listManagedQueuedSalvageFilters_(labelId);
      const exactMatch = managedFilters.find(function(filter) {
        return areFiltersEquivalent_(filter, desiredFilter);
      });

      if (exactMatch) {
        filterId = exactMatch.id || '';
        filterAction = 'kept_existing';
        managedFilters.forEach(function(filter) {
          if (!filter.id || filter.id === filterId) return;
          gmailFilterRemove_(filter.id);
        });
      } else {
        managedFilters.forEach(function(filter) {
          if (!filter.id) return;
          gmailFilterRemove_(filter.id);
        });
        const created = gmailFilterCreate_(desiredFilter);
        filterId = created && created.id ? created.id : '';
        filterAction = 'created_or_replaced';
      }
    } catch (err) {
      filterAction = 'skipped_rest_error';
      filterError = String(err && err.message ? err.message : err);
    }
  }

  const relabeledThreadCount = SALVAGE_CONFIG.gmail.backfillLabelOnEveryRun
    ? backfillQueuedSalvageLabel_(label)
    : 0;

  return {
    label: label,
    labelId: labelId,
    filterId: filterId,
    filterAction: filterAction,
    filterError: filterError,
    relabeledThreadCount: relabeledThreadCount,
  };
}

function ensureGmailLabel_(labelName) {
  let label = GmailApp.getUserLabelByName(labelName);
  if (!label) {
    label = GmailApp.createLabel(labelName);
  }
  return label;
}

function buildEligibleGmailSearchQuery_() {
  return [
    'from:' + quoteGmailSearchValue_(SALVAGE_CONFIG.gmail.from),
    'subject:' + quoteGmailSearchValue_(SALVAGE_CONFIG.gmail.subject),
    'has:attachment',
    'filename:' + SALVAGE_CONFIG.gmail.attachmentExtension.replace(/^\./, ''),
    quoteGmailSearchValue_(SALVAGE_CONFIG.gmail.attachmentKeyword),
    '-in:trash',
  ].join(' ');
}

function buildManagedGmailFilterDefinition_(labelId) {
  return {
    criteria: {
      from: SALVAGE_CONFIG.gmail.from,
      subject: SALVAGE_CONFIG.gmail.subject,
      hasAttachment: true,
      query: 'filename:' + SALVAGE_CONFIG.gmail.attachmentExtension.replace(/^\./, '') + ' ' + quoteGmailSearchValue_(SALVAGE_CONFIG.gmail.attachmentKeyword),
    },
    action: {
      addLabelIds: [labelId],
    },
  };
}

function listManagedQueuedSalvageFilters_(labelId) {
  const listResponse = gmailFilterList_();
  const filters = listResponse && listResponse.filter ? listResponse.filter : [];
  return filters.filter(function(filter) {
    const criteria = filter.criteria || {};
    const action = filter.action || {};
    const addLabelIds = action.addLabelIds || [];
    return addLabelIds.indexOf(labelId) !== -1 &&
      String(criteria.from || '').toLowerCase() === SALVAGE_CONFIG.gmail.from.toLowerCase() &&
      String(criteria.subject || '') === SALVAGE_CONFIG.gmail.subject;
  });
}

function areFiltersEquivalent_(left, right) {
  const leftCriteria = left && left.criteria ? left.criteria : {};
  const rightCriteria = right && right.criteria ? right.criteria : {};
  const leftAction = left && left.action ? left.action : {};
  const rightAction = right && right.action ? right.action : {};
  const leftLabelIds = (leftAction.addLabelIds || []).slice().sort().join(',');
  const rightLabelIds = (rightAction.addLabelIds || []).slice().sort().join(',');
  return String(leftCriteria.from || '').toLowerCase() === String(rightCriteria.from || '').toLowerCase() &&
    String(leftCriteria.subject || '') === String(rightCriteria.subject || '') &&
    !!leftCriteria.hasAttachment === !!rightCriteria.hasAttachment &&
    normalizeWhitespace_(leftCriteria.query || '') === normalizeWhitespace_(rightCriteria.query || '') &&
    leftLabelIds === rightLabelIds;
}

function backfillQueuedSalvageLabel_(label) {
  const query = buildEligibleGmailSearchQuery_();
  const threads = GmailApp.search(query, 0, SALVAGE_CONFIG.gmail.backfillSearchLimitThreads);
  if (!threads.length) return 0;
  label.addToThreads(threads);
  return threads.length;
}

function quoteGmailSearchValue_(value) {
  return '"' + String(value || '').replace(/"/g, '\"') + '"';
}

function normalizeWhitespace_(value) {
  return String(value || '').replace(/\s+/g, ' ').trim();
}

function truncateForLog_(value, maxLen) {
  const str = String(value || '');
  const limit = Math.max(Number(maxLen) || 0, 0);
  if (!limit || str.length <= limit) return str;
  return str.slice(0, Math.max(limit - 3, 0)) + '...';
}

function gmailFilterList_() {
  return gmailSettingsRequest_('get', '/gmail/v1/users/me/settings/filters');
}

function gmailFilterCreate_(payload) {
  return gmailSettingsRequest_('post', '/gmail/v1/users/me/settings/filters', payload);
}

function gmailFilterRemove_(filterId) {
  gmailSettingsRequest_('delete', '/gmail/v1/users/me/settings/filters/' + encodeURIComponent(filterId));
}

function gmailSettingsRequest_(method, path, payload) {
  const response = UrlFetchApp.fetch('https://gmail.googleapis.com' + path, {
    method: String(method || 'get').toLowerCase(),
    muteHttpExceptions: true,
    headers: {
      Authorization: 'Bearer ' + ScriptApp.getOAuthToken(),
    },
    contentType: 'application/json',
    payload: payload ? JSON.stringify(payload) : undefined,
  });

  const status = response.getResponseCode();
  const bodyText = response.getContentText() || '';

  if (status >= 200 && status < 300) {
    return bodyText ? JSON.parse(bodyText) : {};
  }

  throw new Error('Gmail settings request failed (' + status + '): ' + truncateForLog_(bodyText, 250));
}

function findLatestEligibleEmail_() {
  const label = GmailApp.getUserLabelByName(SALVAGE_CONFIG.gmail.labelName);
  if (!label) {
    throw new Error('Gmail label not found: ' + SALVAGE_CONFIG.gmail.labelName);
  }

  const query = buildEligibleGmailSearchQuery_();
  let threads = label.getThreads(0, SALVAGE_CONFIG.gmail.scanLimitThreads);
  let sourceMode = 'label';

  if (!threads.length) {
    threads = GmailApp.search(query, 0, SALVAGE_CONFIG.gmail.scanLimitThreads);
    if (threads.length) {
      sourceMode = 'search_fallback';
      label.addToThreads(threads);
    }
  }

  let best = null;
  let matchedCount = 0;

  threads.forEach(function(thread) {
    const messages = thread.getMessages();
    messages.forEach(function(message) {
      const fromRaw = String(message.getFrom() || '');
      const fromEmail = extractEmailAddress_(fromRaw);
      const subject = String(message.getSubject() || '').trim();

      if (SALVAGE_CONFIG.gmail.strictFromMatch) {
        if (fromEmail !== SALVAGE_CONFIG.gmail.from.toLowerCase()) return;
      } else {
        if (fromRaw.toLowerCase().indexOf(SALVAGE_CONFIG.gmail.from.toLowerCase()) === -1) return;
      }
      if (subject !== SALVAGE_CONFIG.gmail.subject) return;

      const attachments = message.getAttachments({ includeInlineImages: false, includeAttachments: true });
      const matchedAttachments = attachments.filter(function(att) {
        const name = String(att.getName() || '');
        return (
          name.toLowerCase().indexOf(SALVAGE_CONFIG.gmail.attachmentKeyword.toLowerCase()) !== -1 &&
          name.toLowerCase().endsWith(SALVAGE_CONFIG.gmail.attachmentExtension)
        );
      });

      if (!matchedAttachments.length) return;
      matchedCount += matchedAttachments.length;

      matchedAttachments.forEach(function(matchedAttachment) {
        const candidateDate = message.getDate().getTime();
        const candidateName = String(matchedAttachment.getName() || '');
        if (!best || candidateDate > best.message.getDate().getTime() || (
          candidateDate === best.message.getDate().getTime() && candidateName > String(best.attachment.getName() || '')
        )) {
          best = {
            thread: thread,
            message: message,
            attachment: matchedAttachment,
            meta: {
              threadCountScanned: threads.length,
              matchedCount: matchedCount,
              sourceMode: sourceMode,
              searchQuery: query,
            },
          };
        }
      });
    });
  });

  if (best) {
    best.meta.matchedCount = matchedCount;
  }

  return best;
}

function convertAttachmentToTempSpreadsheet_(attachment) {
  const blob = attachment.copyBlob().setName(attachment.getName());
  const tempName = SALVAGE_CONFIG.temp.filePrefix + attachment.getName().replace(/\.[^.]+$/, '');

  const fileMetadata = {
    name: tempName,
    mimeType: 'application/vnd.google-apps.spreadsheet',
  };

  const created = Drive.Files.create(fileMetadata, blob, { fields: 'id,name,mimeType' });

  if (!created || !created.id) {
    throw new Error('Failed to convert attachment into temporary Google Spreadsheet.');
  }

  return created.id;
}

function readSourceSnapshot_(tempSpreadsheetId) {
  const ss = SpreadsheetApp.openById(tempSpreadsheetId);
  const sheets = ss.getSheets();
  if (!sheets.length) {
    throw new Error('Temporary spreadsheet has no sheets.');
  }

  const requiredGroups = Object.keys(SALVAGE_TARGET_TO_SOURCE_ALIASES).map(function(key) {
    return SALVAGE_TARGET_TO_SOURCE_ALIASES[key];
  });

  let bestCandidate = null;
  sheets.forEach(function(sheet) {
    const detection = detectHeaderRow_(sheet, requiredGroups, SALVAGE_CONFIG.target.headerSearchRows);
    if (!detection) return;
    const dataRows = Math.max(sheet.getLastRow() - detection.headerRow, 0);
    if (!bestCandidate || detection.score > bestCandidate.score || (
      detection.score === bestCandidate.score && dataRows > bestCandidate.dataRows
    )) {
      bestCandidate = {
        sheet: sheet,
        headerRow: detection.headerRow,
        score: detection.score,
        dataRows: dataRows,
      };
    }
  });

  if (!bestCandidate) {
    throw new Error('Could not detect source header row in the temporary spreadsheet.');
  }

  const headerMap = buildHeaderMap_(bestCandidate.sheet, bestCandidate.headerRow);
  const sourceColumnMap = resolveAliasMap_(headerMap, SALVAGE_TARGET_TO_SOURCE_ALIASES, 'source');

  const lastRow = bestCandidate.sheet.getLastRow();
  const lastCol = bestCandidate.sheet.getLastColumn();
  const headers = bestCandidate.sheet.getRange(bestCandidate.headerRow, 1, 1, lastCol).getDisplayValues()[0];

  if (lastRow <= bestCandidate.headerRow) {
    return {
      availableSheets: sheets.map(function(s) { return s.getName(); }),
      sheetName: bestCandidate.sheet.getName(),
      headerRow: bestCandidate.headerRow,
      headers: headers,
      resolvedColumnMap: sourceColumnMap,
      rawRows: 0,
      sampleClaims: [],
      sourceByClaim: {},
      duplicateClaimNumbers: [],
    };
  }

  const values = bestCandidate.sheet
    .getRange(bestCandidate.headerRow + 1, 1, lastRow - bestCandidate.headerRow, lastCol)
    .getValues();

  const sourceByClaim = {};
  const duplicates = [];
  let rawRows = 0;

  values.forEach(function(row) {
    const claimNumber = normalizeKey_(row[sourceColumnMap['Claim Number'] - 1]);
    if (!claimNumber) return;

    rawRows += 1;

    if (sourceByClaim[claimNumber]) {
      duplicates.push(claimNumber);
    }

    const record = {};
    Object.keys(SALVAGE_TARGET_TO_SOURCE_ALIASES).forEach(function(targetHeader) {
      const colIndex = sourceColumnMap[targetHeader];
      record[targetHeader] = colIndex ? row[colIndex - 1] : '';
    });
    sourceByClaim[claimNumber] = record;
  });

  return {
    availableSheets: sheets.map(function(s) { return s.getName(); }),
    sheetName: bestCandidate.sheet.getName(),
    headerRow: bestCandidate.headerRow,
    headers: headers,
    resolvedColumnMap: sourceColumnMap,
    rawRows: rawRows,
    sampleClaims: Object.keys(sourceByClaim).slice(0, SALVAGE_CONFIG.target.sampleSize),
    sourceByClaim: sourceByClaim,
    duplicateClaimNumbers: Array.from(new Set(duplicates)),
  };
}


function buildSyncDiffPreview_(sourceSnapshot, precheckedTargetSnapshot) {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  if (!sheet) {
    throw new Error('Target sheet not found: ' + SALVAGE_CONFIG.target.sheetName);
  }

  const targetSnapshot = precheckedTargetSnapshot || inspectTargetSnapshot_();
  if (targetSnapshot.duplicateClaimCount > 0) {
    throw new Error('Duplicate Claim Number ditemukan di target sheet. Preview dihentikan.');
  }

  const headerRow = targetSnapshot.headerRow;
  const targetColumnMap = targetSnapshot.columnMap;
  const dataStartRow = headerRow + 1;
  const existingRangeRowCount = Math.max(targetSnapshot.lastRow - headerRow, 0);
  const claimCol = targetColumnMap['Claim Number'];

  let values = [];
  let claimNotes = [];
  if (existingRangeRowCount > 0) {
    values = sheet.getRange(dataStartRow, 1, existingRangeRowCount, targetSnapshot.lastCol).getValues();
    claimNotes = sheet.getRange(dataStartRow, claimCol, existingRangeRowCount, 1).getNotes();
  }

  const claimRowIndex = {};
  values.forEach(function(row, idx) {
    const claim = normalizeKey_(row[claimCol - 1]);
    if (!claim) return;
    if (claimRowIndex[claim] !== undefined) return;
    claimRowIndex[claim] = idx;
  });

  const sourceClaims = Object.keys(sourceSnapshot.sourceByClaim || {});
  const updateSamples = [];
  const insertSamples = [];
  const restoreSamples = [];
  const missingSamples = [];
  let updateCount = 0;
  let insertCount = 0;
  let restoreCount = 0;

  sourceClaims.forEach(function(claim) {
    const rowIndex = claimRowIndex[claim];
    if (rowIndex === undefined) {
      insertCount += 1;
      if (insertSamples.length < SALVAGE_CONFIG.target.sampleSize) {
        insertSamples.push(claim);
      }
      return;
    }

    updateCount += 1;
    if (updateSamples.length < SALVAGE_CONFIG.target.sampleSize) {
      updateSamples.push(claim);
    }

    const existingNote = String(claimNotes[rowIndex] && claimNotes[rowIndex][0] || '');
    if (existingNote === SALVAGE_CONFIG.target.claimMissingNote) {
      restoreCount += 1;
      if (restoreSamples.length < SALVAGE_CONFIG.target.sampleSize) {
        restoreSamples.push(claim);
      }
    }
  });

  let missingExistingCount = 0;
  Object.keys(claimRowIndex).forEach(function(claim) {
    if (sourceSnapshot.sourceByClaim[claim]) return;
    missingExistingCount += 1;
    if (missingSamples.length < SALVAGE_CONFIG.target.sampleSize) {
      missingSamples.push(claim);
    }
  });

  return {
    status: 'PREVIEW_ONLY',
    targetSheetName: targetSnapshot.sheetName,
    targetHeaderRow: headerRow,
    sourceSheetName: sourceSnapshot.sheetName,
    sourceHeaderRow: sourceSnapshot.headerRow,
    sourceUniqueClaims: sourceClaims.length,
    targetExistingClaimRows: targetSnapshot.claimRowCount,
    updateCount: updateCount,
    insertCount: insertCount,
    missingExistingCount: missingExistingCount,
    restoreCount: restoreCount,
    blankGapCount: targetSnapshot.blankGapCount,
    blankGapSamples: targetSnapshot.blankGapSamples,
    updateSamples: updateSamples,
    insertSamples: insertSamples,
    missingSamples: missingSamples,
    restoreSamples: restoreSamples,
  };
}

function syncTargetSheet_(sourceSnapshot, precheckedTargetSnapshot) {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  if (!sheet) {
    throw new Error('Target sheet not found: ' + SALVAGE_CONFIG.target.sheetName);
  }

  const targetSnapshot = precheckedTargetSnapshot || inspectTargetSnapshot_();
  const headerRow = targetSnapshot.headerRow;
  const targetColumnMap = targetSnapshot.columnMap;
  const lastCol = targetSnapshot.lastCol;
  const dataStartRow = headerRow + 1;
  const existingRangeRowCount = Math.max(targetSnapshot.lastRow - headerRow, 0);
  const claimCol = targetColumnMap['Claim Number'];

  let values = [];
  let claimBackgrounds = [];
  let claimNotes = [];

  if (existingRangeRowCount > 0) {
    values = sheet.getRange(dataStartRow, 1, existingRangeRowCount, lastCol).getValues();
    claimBackgrounds = sheet.getRange(dataStartRow, claimCol, existingRangeRowCount, 1).getBackgrounds();
    claimNotes = sheet.getRange(dataStartRow, claimCol, existingRangeRowCount, 1).getNotes();
  }

  if (targetSnapshot.duplicateClaimCount > 0) {
    throwDuplicateTargetError_(targetSnapshot);
  }

  const claimRowIndex = {};
  values.forEach(function(row, idx) {
    const claim = normalizeKey_(row[claimCol - 1]);
    if (!claim) return;
    if (claimRowIndex[claim] !== undefined) {
      return;
    }
    claimRowIndex[claim] = idx;
  });

  const sourceClaims = Object.keys(sourceSnapshot.sourceByClaim);
  let updatedCount = 0;
  let insertedCount = 0;
  let restoredCount = 0;

  sourceClaims.forEach(function(claim) {
    const record = sourceSnapshot.sourceByClaim[claim];
    let rowIndex = claimRowIndex[claim];
    const isInsert = rowIndex === undefined;

    if (isInsert) {
      const newRow = createEmptyRow_(lastCol);
      values.push(newRow);
      claimBackgrounds.push([SALVAGE_CONFIG.target.defaultCellColor]);
      claimNotes.push(['']);
      rowIndex = values.length - 1;
      claimRowIndex[claim] = rowIndex;
      insertedCount += 1;
    } else {
      updatedCount += 1;
    }

    Object.keys(SALVAGE_TARGET_TO_SOURCE_ALIASES).forEach(function(targetHeader) {
      const targetCol = targetColumnMap[targetHeader];
      values[rowIndex][targetCol - 1] = record[targetHeader];
    });

    const existingNote = String(claimNotes[rowIndex] && claimNotes[rowIndex][0] || '');
    if (existingNote === SALVAGE_CONFIG.target.claimMissingNote) {
      restoredCount += 1;
    }
    claimBackgrounds[rowIndex][0] = SALVAGE_CONFIG.target.defaultCellColor;
    claimNotes[rowIndex][0] = '';
  });

  let missingExistingCount = 0;
  Object.keys(claimRowIndex).forEach(function(claim) {
    if (sourceSnapshot.sourceByClaim[claim]) return;
    const rowIndex = claimRowIndex[claim];
    missingExistingCount += 1;
    claimBackgrounds[rowIndex][0] = SALVAGE_CONFIG.target.claimMissingColor;
    claimNotes[rowIndex][0] = SALVAGE_CONFIG.target.claimMissingNote;
  });

  const finalRowCount = values.length;
  if (finalRowCount > 0) {
    ensureSheetHasRows_(sheet, headerRow + finalRowCount);

    Object.keys(SALVAGE_TARGET_TO_SOURCE_ALIASES).forEach(function(targetHeader) {
      const targetCol = targetColumnMap[targetHeader];
      const columnValues = values.map(function(row) {
        return [row[targetCol - 1]];
      });
      sheet.getRange(dataStartRow, targetCol, finalRowCount, 1).setValues(columnValues);
    });

    sheet.getRange(dataStartRow, claimCol, finalRowCount, 1).setBackgrounds(claimBackgrounds);
    sheet.getRange(dataStartRow, claimCol, finalRowCount, 1).setNotes(claimNotes);
  }

  SpreadsheetApp.flush();

  return {
    updatedCount: updatedCount,
    insertedCount: insertedCount,
    missingExistingCount: missingExistingCount,
    restoredCount: restoredCount,
    targetHeaderRow: headerRow,
    targetSheetName: targetSnapshot.sheetName,
    existingClaimRowsBeforeRun: targetSnapshot.claimRowCount,
    blankGapCount: targetSnapshot.blankGapCount,
    blankGapSamples: targetSnapshot.blankGapSamples,
    duplicateTargetClaimCount: targetSnapshot.duplicateClaimCount,
    duplicateTargetClaimSamples: targetSnapshot.duplicateClaimSamples,
    finalRowCount: finalRowCount,
  };
}


function throwDuplicateTargetError_(targetSnapshot) {
  const samples = (targetSnapshot && targetSnapshot.duplicateClaimSamples || []).slice(0, 3).join(' | ');
  const message = 'Duplicate Claim Number ditemukan di target sheet. Sync dihentikan.' + (samples ? ' Contoh: ' + samples : '');
  throw new Error(message);
}

function inspectTargetSnapshot_() {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  if (!sheet) {
    throw new Error('Target sheet not found: ' + SALVAGE_CONFIG.target.sheetName);
  }

  const headerRow = resolveTargetHeaderRow_(sheet);
  const targetHeaderMap = buildHeaderMap_(sheet, headerRow);
  const targetColumnMap = resolveAliasMap_(targetHeaderMap, SALVAGE_TARGET_HEADER_ALIASES, 'target');
  const lastCol = Math.max(sheet.getLastColumn(), Math.max.apply(null, Object.keys(targetColumnMap).map(function(k) {
    return targetColumnMap[k];
  })));
  const headers = sheet.getRange(headerRow, 1, 1, lastCol).getDisplayValues()[0];
  const claimCol = targetColumnMap['Claim Number'];
  const claimScan = getClaimColumnScan_(sheet, headerRow, claimCol);

  return {
    spreadsheetId: ss.getId(),
    spreadsheetName: ss.getName(),
    sheetName: sheet.getName(),
    headerRow: headerRow,
    columnMap: targetColumnMap,
    headers: headers,
    lastRow: sheet.getLastRow(),
    lastCol: lastCol,
    claimRowCount: claimScan.claimRowCount,
    blankGapCount: claimScan.blankGapCount,
    blankGapSamples: claimScan.blankGapSamples,
    duplicateClaimCount: claimScan.duplicateClaimCount,
    duplicateClaimSamples: claimScan.duplicateClaimSamples,
    lastClaimRow: claimScan.lastClaimRow,
    sampleClaims: claimScan.sampleClaims,
  };
}

function resolveTargetHeaderRow_(sheet) {
  if (SALVAGE_CONFIG.target.fixedHeaderRow) {
    return SALVAGE_CONFIG.target.fixedHeaderRow;
  }

  const requiredGroups = Object.keys(SALVAGE_TARGET_HEADER_ALIASES).map(function(key) {
    return SALVAGE_TARGET_HEADER_ALIASES[key];
  });
  const headerDetection = detectHeaderRow_(sheet, requiredGroups, SALVAGE_CONFIG.target.headerSearchRows) || {
    headerRow: SALVAGE_CONFIG.target.dataStartFallbackHeaderRow,
  };
  return headerDetection.headerRow;
}

function getClaimColumnScan_(sheet, headerRow, claimCol) {
  const dataStartRow = headerRow + 1;
  const lastRow = Math.max(sheet.getLastRow(), headerRow);
  const rowCount = Math.max(lastRow - headerRow, 0);
  if (rowCount === 0) {
    return {
      claimRowCount: 0,
      blankGapCount: 0,
      blankGapSamples: [],
      duplicateClaimCount: 0,
      duplicateClaimSamples: [],
      lastClaimRow: headerRow,
      sampleClaims: [],
    };
  }

  const claimValues = sheet.getRange(dataStartRow, claimCol, rowCount, 1).getDisplayValues().map(function(r) {
    return String(r[0] || '');
  });

  const sampleClaims = [];
  const blankGapSamples = [];
  const duplicateClaimSamples = [];
  const seenRowsByClaim = {};
  let claimRowCount = 0;
  let blankGapCount = 0;
  let duplicateClaimCount = 0;
  let lastClaimOffset = -1;

  claimValues.forEach(function(value, idx) {
    const normalized = normalizeKey_(value);
    if (!normalized) return;

    claimRowCount += 1;
    lastClaimOffset = idx;
    if (sampleClaims.length < SALVAGE_CONFIG.target.sampleSize) {
      sampleClaims.push(value);
    }

    if (Object.prototype.hasOwnProperty.call(seenRowsByClaim, normalized)) {
      duplicateClaimCount += 1;
      if (duplicateClaimSamples.length < SALVAGE_CONFIG.target.sampleSize) {
        duplicateClaimSamples.push(value + ' @ row ' + (dataStartRow + idx) + ' (first seen at row ' + seenRowsByClaim[normalized] + ')');
      }
      return;
    }

    seenRowsByClaim[normalized] = dataStartRow + idx;
  });

  if (lastClaimOffset >= 0) {
    for (var i = 0; i <= lastClaimOffset; i += 1) {
      if (!normalizeKey_(claimValues[i])) {
        blankGapCount += 1;
        if (blankGapSamples.length < SALVAGE_CONFIG.target.sampleSize) {
          blankGapSamples.push('row ' + (dataStartRow + i));
        }
      }
    }
  }

  return {
    claimRowCount: claimRowCount,
    blankGapCount: blankGapCount,
    blankGapSamples: blankGapSamples,
    duplicateClaimCount: duplicateClaimCount,
    duplicateClaimSamples: duplicateClaimSamples,
    lastClaimRow: lastClaimOffset >= 0 ? dataStartRow + lastClaimOffset : headerRow,
    sampleClaims: sampleClaims,
  };
}



function verifyPostSync_(sourceSnapshot, targetSnapshot) {
  const post = inspectTargetSnapshot_();
  const sourceClaims = Object.keys(sourceSnapshot.sourceByClaim || {});
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  const claimCol = post.columnMap['Claim Number'];
  const totalRows = Math.max(post.lastRow - post.headerRow, 0);
  const targetClaims = totalRows > 0
    ? sheet.getRange(post.headerRow + 1, claimCol, totalRows, 1).getDisplayValues().map(function(r) {
        return normalizeKey_(r[0]);
      })
    : [];

  const targetClaimSet = {};
  targetClaims.forEach(function(claim) {
    if (claim) targetClaimSet[claim] = true;
  });

  const missingClaims = sourceClaims.filter(function(claim) {
    return !targetClaimSet[claim];
  });

  if (post.duplicateClaimCount > 0) {
    throw new Error('Post-sync verification failed: duplicate Claim Number ditemukan di target sheet.');
  }

  if (sourceClaims.length > 0 && post.claimRowCount === 0) {
    throw new Error('Post-sync verification failed: target sheet still has 0 claim rows after sync.');
  }

  if (missingClaims.length > 0) {
    throw new Error('Post-sync verification failed: source Claim Number(s) not found in target after sync: ' + missingClaims.slice(0, 20).join(', '));
  }

  return {
    targetSheetName: post.sheetName,
    targetHeaderRow: post.headerRow,
    claimRowCount: post.claimRowCount,
    blankGapCount: post.blankGapCount,
    blankGapSamples: post.blankGapSamples,
    duplicateClaimCount: post.duplicateClaimCount,
    duplicateClaimSamples: post.duplicateClaimSamples,
    sourceUniqueClaims: sourceClaims.length,
    previousClaimRows: targetSnapshot ? targetSnapshot.claimRowCount : '',
    verifiedAllSourceClaims: true,
  };
}

function writeTargetRunTimestamp_() {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  if (!sheet) {
    throw new Error('Target sheet not found: ' + SALVAGE_CONFIG.target.sheetName);
  }

  const timestampText = formatTargetRunTimestamp_(new Date());
  sheet.getRange('B1').setValue(timestampText);
}

function writeTargetRunFailureNotice_(error) {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  if (!sheet) {
    throw new Error('Target sheet not found: ' + SALVAGE_CONFIG.target.sheetName);
  }

  const failureText = formatTargetRunFailureNotice_(error);
  sheet.getRange('B1').setValue(failureText);
}

function formatTargetRunFailureNotice_(error) {
  const raw = stringifyError_(error) || 'Run gagal.';
  const compact = String(raw)
    .replace(/\s+/g, ' ')
    .replace(/\.$/, '')
    .trim();

  if (/duplicate claim number/i.test(compact)) {
    return 'Gagal: duplicate Claim Number di target.';
  }
  if (/no eligible email found/i.test(compact)) {
    return 'Info: tidak ada email salvage yang eligible.';
  }
  if (/source spreadsheet is empty/i.test(compact)) {
    return 'Gagal: source salvage kosong.';
  }
  if (/post-sync verification failed/i.test(compact)) {
    return 'Gagal: verifikasi hasil sync tidak lolos.';
  }

  return 'Gagal: ' + compact.slice(0, 110);
}

function formatTargetRunTimestamp_(date) {
  const tz = SALVAGE_CONFIG.scriptTimeZone || Session.getScriptTimeZone() || 'Asia/Jakarta';
  const monthNames = [
    'January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'
  ];
  const monthIndex = Math.max(Number(Utilities.formatDate(date, tz, 'M')) - 1, 0);
  const day = Utilities.formatDate(date, tz, 'd');
  const year = Utilities.formatDate(date, tz, 'yy');
  const time = Utilities.formatDate(date, tz, 'HH:mm');
  return day + ' ' + monthNames[monthIndex] + ' ' + year + ', ' + time;
}

function extractEmailAddress_(value) {
  const raw = String(value || '').trim().toLowerCase();
  const angled = raw.match(/<([^>]+)>/);
  if (angled && angled[1]) return angled[1].trim();
  return raw;
}

function safeJson_(value) {
  try {
    return JSON.stringify(value);
  } catch (error) {
    return String(value);
  }
}

function trashTempFile_(fileId) {
  if (!fileId) return;
  DriveApp.getFileById(fileId).setTrashed(true);
}

function ensureLogSheetLayout_() {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.log.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.log.sheetName);
  if (!sheet) {
    throw new Error('Log sheet not found: ' + SALVAGE_CONFIG.log.sheetName);
  }

  ensureSheetHasRows_(sheet, SALVAGE_CONFIG.log.headerRow);
  ensureSheetHasColumns_(sheet, SALVAGE_CONFIG.log.headerStartColumn + SALVAGE_CONFIG.log.detailHeaders.length - 1);

  const headerRange = sheet.getRange(
    SALVAGE_CONFIG.log.headerRow,
    SALVAGE_CONFIG.log.headerStartColumn,
    1,
    SALVAGE_CONFIG.log.detailHeaders.length
  );
  headerRange.setValues([SALVAGE_CONFIG.log.detailHeaders]);
  headerRange.setFontWeight('bold');

  sheet.getRange(SALVAGE_CONFIG.log.progressPctCell).setNumberFormat('0%');
  SpreadsheetApp.flush();
}

function resetLogDetails_() {
  const sheet = getLogSheet_();
  ensureSheetHasRows_(sheet, SALVAGE_CONFIG.log.headerRow);
  ensureSheetHasColumns_(sheet, SALVAGE_CONFIG.log.headerStartColumn + SALVAGE_CONFIG.log.detailHeaders.length - 1);

  const maxRows = sheet.getMaxRows();

  if (maxRows > SALVAGE_CONFIG.log.headerRow) {
    sheet.getRange(
      SALVAGE_CONFIG.log.headerRow + 1,
      SALVAGE_CONFIG.log.headerStartColumn,
      maxRows - SALVAGE_CONFIG.log.headerRow,
      SALVAGE_CONFIG.log.detailHeaders.length
    ).clearContent().clearNote().clearFormat();
  }

  sheet.getRange(SALVAGE_CONFIG.log.progressBarCell).setValue(buildProgressBar_(0));
  sheet.getRange(SALVAGE_CONFIG.log.progressPctCell).setValue(0);
  sheet.getRange(SALVAGE_CONFIG.log.currentStepCell).setValue('Waiting');
  sheet.getRange(SALVAGE_CONFIG.log.updatedAtCell).setValue(new Date());

  sheet.getRange(SALVAGE_CONFIG.log.headerRow, SALVAGE_CONFIG.log.headerStartColumn, 1, SALVAGE_CONFIG.log.detailHeaders.length)
    .setValues([SALVAGE_CONFIG.log.detailHeaders])
    .setFontWeight('bold');

  SpreadsheetApp.flush();
}

function updateProgress_(percent, stepText) {
  const clamped = Math.max(0, Math.min(100, percent));
  const sheet = getLogSheet_();
  sheet.getRange(SALVAGE_CONFIG.log.progressBarCell).setValue(buildProgressBar_(clamped));
  sheet.getRange(SALVAGE_CONFIG.log.progressPctCell).setValue(clamped / 100);
  sheet.getRange(SALVAGE_CONFIG.log.currentStepCell).setValue(stepText);
  sheet.getRange(SALVAGE_CONFIG.log.updatedAtCell).setValue(new Date());
  SpreadsheetApp.flush();
}

function logStage_(ctx, payload) {
  const sheet = getLogSheet_();
  const rowNumber = Math.max(sheet.getLastRow() + 1, SALVAGE_CONFIG.log.headerRow + 1);

  const logIndex = rowNumber - SALVAGE_CONFIG.log.headerRow - 0;
  const ts = new Date();
  const durationMs = payload.durationMs === undefined || payload.durationMs === null ? '' : payload.durationMs;
  const durationReadable = durationMs === '' ? '' : (durationMs + ' ms / ' + (durationMs / 1000).toFixed(3) + ' s');

  const row = [
    logIndex,
    ts,
    ctx.flow || SALVAGE_CONFIG.flowName,
    ctx.runId || '',
    payload.stage || '',
    payload.segment || '',
    durationReadable,
    ctx.emailFrom || '',
    ctx.emailSubject || '',
    ctx.threadId || '',
    ctx.attachmentName || '',
    ctx.attachmentSize || '',
    ctx.attachmentType || '',
    valueOrBlank_(payload.rawRows),
    valueOrBlank_(payload.opsUpdated),
    valueOrBlank_(payload.subInserted),
    payload.status || '',
    payload.error || '',
    payload.metrics || '',
    payload.notes || '',
    payload.severity || '',
  ];

  sheet.getRange(rowNumber, SALVAGE_CONFIG.log.headerStartColumn, 1, row.length).setValues([row]);
  sheet.getRange(SALVAGE_CONFIG.log.updatedAtCell).setValue(ts);
  SpreadsheetApp.flush();
}

function listTargetDuplicateClaims_() {
  const targetSnapshot = inspectTargetSnapshot_();
  if (!targetSnapshot.duplicateClaimCount) {
    return [];
  }

  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.target.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.target.sheetName);
  const claimCol = targetSnapshot.columnMap['Claim Number'];
  const dataStartRow = targetSnapshot.headerRow + 1;
  const totalRows = Math.max(targetSnapshot.lastRow - targetSnapshot.headerRow, 0);
  const claimValues = totalRows > 0
    ? sheet.getRange(dataStartRow, claimCol, totalRows, 1).getDisplayValues().map(function(r) { return String(r[0] || ''); })
    : [];

  const seen = {};
  const duplicates = [];
  claimValues.forEach(function(value, idx) {
    const normalized = normalizeKey_(value);
    if (!normalized) return;
    const rowNumber = dataStartRow + idx;
    if (Object.prototype.hasOwnProperty.call(seen, normalized)) {
      duplicates.push({
        claimNumber: value,
        firstRow: seen[normalized],
        duplicateRow: rowNumber,
      });
      return;
    }
    seen[normalized] = rowNumber;
  });

  return duplicates;
}

function diagnoseTargetDuplicateClaims() {
  const duplicates = listTargetDuplicateClaims_();
  Logger.log(JSON.stringify(duplicates.slice(0, 50), null, 2));
  return duplicates;
}

function getLogSheet_() {
  const ss = SpreadsheetApp.openById(SALVAGE_CONFIG.log.spreadsheetId);
  const sheet = ss.getSheetByName(SALVAGE_CONFIG.log.sheetName);
  if (!sheet) {
    throw new Error('Log sheet not found: ' + SALVAGE_CONFIG.log.sheetName);
